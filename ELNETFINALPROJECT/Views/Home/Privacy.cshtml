@{
    ViewData["Title"] = "Privacy Policy & Terms - GameTime";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <style>
        *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            background: #0d1f2d;
            color: #c0cad4;
            min-height: 100vh;
            padding: 48px 20px;
        }
        .container {
            max-width: 780px;
            margin: 0 auto;
        }
        .back-link {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            color: #00ff88;
            text-decoration: none;
            font-size: 13px;
            font-weight: 600;
            letter-spacing: 0.5px;
            margin-bottom: 36px;
        }
        .back-link:hover { opacity: 0.8; }
        h1 {
            font-size: 36px;
            font-weight: 900;
            color: #ffffff;
            margin-bottom: 8px;
        }
        .updated {
            font-size: 13px;
            color: #556677;
            margin-bottom: 40px;
        }
        h2 {
            font-size: 18px;
            font-weight: 700;
            color: #00ff88;
            margin: 32px 0 12px;
        }
        p, li {
            font-size: 15px;
            line-height: 1.8;
            color: #8a9aaa;
        }
        ul { padding-left: 20px; margin-top: 8px; }
        li { margin-bottom: 6px; }
        .divider {
            border: none;
            border-top: 1px solid rgba(255,255,255,0.07);
            margin: 40px 0;
        }
    </style>
</head>
<body>
    <div class="container">
        <a asp-controller="Home" asp-action="Index" class="back-link"><i class="bi bi-arrow-left"></i> Back to Home</a>

        <h1>Privacy Policy &amp; Terms</h1>
        <p class="updated">Last updated: May 2026 &mdash; GameTime Management System</p>

        <h2>1. Data We Collect</h2>
        <p>When you register and use GameTime, we collect the following information:</p>
        <ul>
            <li>Account credentials (username, email, hashed password)</li>
            <li>Session history including playtime and station usage</li>
            <li>Profile information such as display name and profile picture</li>
            <li>Balance and transaction records</li>
        </ul>

        <h2>2. How We Use Your Data</h2>
        <p>Your data is used solely to operate the GameTime platform:</p>
        <ul>
            <li>To authenticate you and manage your account</li>
            <li>To track gaming sessions and billing</li>
            <li>To display statistics and rank progression</li>
            <li>To improve the platform experience</li>
        </ul>

        <h2>3. Data Security</h2>
        <p>All passwords are stored using SHA-256 hashing. Your data is stored locally on our secure servers and is never shared with third parties. We do not use external analytics services.</p>

        <h2>4. Session Cookies</h2>
        <p>GameTime uses server-side sessions to keep you authenticated. These sessions expire after 30 minutes of inactivity and are cleared upon logout. Sessions are marked HttpOnly and essential for the application to function.</p>

        <h2>5. Your Rights</h2>
        <p>You may request deletion of your account by contacting an administrator. Upon deletion, all associated data including playtime history and balance will be permanently removed.</p>

        <hr class="divider" />

        <h2>Terms of Use</h2>
        <p>By using GameTime, you agree to:</p>
        <ul>
            <li>Use the platform only for lawful purposes</li>
            <li>Not share your account credentials with others</li>
            <li>Not attempt to manipulate session timers or balances</li>
            <li>Respect all other players and staff</li>
        </ul>

        <p style="margin-top:32px; color:#556677; font-size:13px;">&copy; 2026 GameTime Management System. All rights reserved.</p>
    </div>
</body>
</html>
