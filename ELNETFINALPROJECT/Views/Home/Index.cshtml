@{
    ViewData["Title"] = "GameTime Management System";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
            background: linear-gradient(135deg, #0d1f2d 0%, #1a2f3f 50%, #0d2438 100%);
            color: #ffffff;
            min-height: 100vh;
            overflow-x: hidden;
        }

        /* Header & Navigation */
        .navbar-custom {
            background: linear-gradient(135deg, rgba(13, 31, 45, 0.95) 0%, rgba(26, 47, 63, 0.95) 100%) !important;
            padding: 20px 0;
            border: none !important;
            position: sticky;
            top: 0;
            z-index: 1000;
            backdrop-filter: blur(10px);
            box-shadow: 0 2px 20px rgba(0, 255, 136, 0.1);
        }

        .navbar-brand {
            font-size: 18px;
            font-weight: 700;
            letter-spacing: 2px;
            color: #ffffff !important;
        }

        .navbar-brand span {
            color: #00ff88;
        }

        .nav-link {
            color: #b0b8c1 !important;
            font-size: 14px;
            margin: 0 15px;
            transition: color 0.3s ease;
        }

        .nav-link:hover {
            color: #00ff88 !important;
        }

        /* Main Content Section */
        .landing-container {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            padding: 40px 20px;
        }

        .badge-custom {
            display: inline-block;
            background: rgba(0, 255, 136, 0.1);
            border: 1px solid #00ff88;
            color: #00ff88;
            padding: 8px 16px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
            letter-spacing: 1px;
            margin-bottom: 30px;
            text-transform: uppercase;
        }

        .hero-section {
            text-align: center;
            margin-bottom: 50px;
        }

        .hero-title {
            font-size: 72px;
            font-weight: 900;
            line-height: 1.1;
            margin-bottom: 20px;
            letter-spacing: -2px;
        }

        .hero-subtitle {
            font-size: 18px;
            color: #7a8a99;
            max-width: 600px;
            margin: 0 auto 50px;
            line-height: 1.6;
        }

        /* Admin Access Box */
        .admin-access-box {
            background: rgba(30, 45, 60, 0.8);
            border: 1px solid rgba(0, 255, 136, 0.2);
            border-radius: 12px;
            padding: 40px;
            max-width: 500px;
            width: 100%;
            margin-bottom: 80px;
            backdrop-filter: blur(10px);
        }

        .admin-label {
            display: block;
            font-size: 12px;
            font-weight: 600;
            color: #b0b8c1;
            margin-bottom: 15px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .password-input-wrapper {
            position: relative;
            margin-bottom: 25px;
        }

        .password-input {
            width: 100%;
            background: rgba(20, 35, 50, 0.8);
            border: 1px solid rgba(0, 255, 136, 0.3);
            border-radius: 8px;
            padding: 15px 45px 15px 15px;
            color: #ffffff;
            font-size: 16px;
            outline: none;
            transition: all 0.3s ease;
        }

        .password-input::placeholder {
            color: #556677;
        }

        .password-input:focus {
            border-color: #00ff88;
            box-shadow: 0 0 20px rgba(0, 255, 136, 0.2);
            background: rgba(20, 35, 50, 0.95);
        }

        .password-toggle {
            position: absolute;
            right: 15px;
            top: 50%;
            transform: translateY(-50%);
            background: none;
            border: none;
            color: #00ff88;
            cursor: pointer;
            font-size: 18px;
            padding: 0;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .enter-btn {
            width: 100%;
            background: linear-gradient(135deg, #00ff88 0%, #00cc6f 100%);
            color: #0d1f2d !important;
            border: none;
            border-radius: 8px;
            padding: 15px;
            font-size: 16px;
            font-weight: 700;
            letter-spacing: 1px;
            text-transform: uppercase;
            cursor: pointer;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            margin-bottom: 15px;
        }

        .enter-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 30px rgba(0, 255, 136, 0.3);
        }

        .enter-btn:active {
            transform: translateY(0);
        }

        .encrypted-note {
            font-size: 12px;
            color: #556677;
            text-align: center;
        }

        .encrypted-note i {
            color: #00ff88;
            margin-right: 5px;
        }

        /* Team Section */
        .team-section {
            width: 100%;
            padding: 60px 20px;
            margin-top: 40px;
        }

        .team-badge {
            display: inline-block;
            background: rgba(0, 255, 136, 0.15);
            border: 1px solid #00ff88;
            color: #00ff88;
            padding: 8px 16px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
            letter-spacing: 1px;
            margin-bottom: 40px;
            text-transform: uppercase;
        }

        .team-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 30px;
            max-width: 1200px;
            margin: 0 auto;
        }

        .team-card {
            background: rgba(30, 45, 60, 0.6);
            border: 1px solid rgba(0, 255, 136, 0.1);
            border-radius: 12px;
            padding: 30px 20px;
            text-align: center;
            transition: all 0.3s ease;
            backdrop-filter: blur(5px);
        }

        .team-card:hover {
            border-color: rgba(0, 255, 136, 0.3);
            transform: translateY(-5px);
            background: rgba(30, 45, 60, 0.8);
        }

        .team-avatar {
            width: 80px;
            height: 80px;
            background: linear-gradient(135deg, #00ff88 0%, #00cc6f 100%);
            border-radius: 50%;
            margin: 0 auto 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 32px;
            color: #0d1f2d;
            font-weight: 700;
        }

        .team-name {
            font-size: 18px;
            font-weight: 600;
            margin-bottom: 8px;
            color: #ffffff;
        }

        .team-role {
            font-size: 12px;
            color: #00ff88;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 12px;
        }

        .team-description {
            font-size: 14px;
            color: #7a8a99;
            line-height: 1.5;
        }

        /* Support Modal */
        .support-modal {
            display: none;
            position: fixed;
            z-index: 2000;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0, 0, 0, 0.5);
            align-items: center;
            justify-content: center;
        }

        .support-modal.show {
            display: flex;
        }

        .support-modal-content {
            background: linear-gradient(135deg, rgba(13, 31, 45, 0.98) 0%, rgba(26, 47, 63, 0.98) 100%);
            border: 1px solid rgba(0, 255, 136, 0.3);
            border-radius: 12px;
            padding: 40px;
            max-width: 450px;
            text-align: center;
            box-shadow: 0 10px 50px rgba(0, 0, 0, 0.5);
            backdrop-filter: blur(10px);
            animation: slideIn 0.3s ease-out;
        }

        @@keyframes slideIn {
            from {
                opacity: 0;
                transform: translateY(-20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .support-modal-content h2 {
            color: #00ff88;
            margin-bottom: 20px;
            font-size: 24px;
            font-weight: 700;
        }

        .support-modal-content p {
            color: #b0b8c1;
            margin-bottom: 10px;
            font-size: 16px;
            line-height: 1.6;
        }

        .support-email {
            color: #00ff88;
            font-weight: 600;
            font-size: 18px;
            margin: 20px 0;
        }

        .modal-close-btn {
            background: linear-gradient(135deg, #00ff88 0%, #00cc6f 100%);
            color: #0d1f2d;
            border: none;
            border-radius: 8px;
            padding: 12px 30px;
            font-weight: 700;
            cursor: pointer;
            margin-top: 20px;
            transition: all 0.3s ease;
        }

        .modal-close-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 30px rgba(0, 255, 136, 0.3);
        }

        /* Responsive */
        @@media (max-width: 768px) {
            .hero-title {
                font-size: 48px;
            }

            .hero-subtitle {
                font-size: 16px;
            }

            .admin-access-box {
                padding: 30px 20px;
            }

            .team-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
    <!-- Navigation -->
    <nav class="navbar navbar-expand-lg navbar-custom">
        <div class="container-fluid px-4">
            <a class="navbar-brand" href="#"><span>GAME</span>TIME MANAGEMENT SYSTEM</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon" style="filter: brightness(0) invert(1);"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="#" onclick="showSupportPopup(event)">Support</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Main Landing Section -->
    <div class="landing-container">
        <div class="badge-custom">
            <i class="bi bi-shield-check"></i> Secure Access Protocol
        </div>

        <div class="hero-section">
            <h1 class="hero-title">WELCOME TO<br>GAMETIME</h1>
            <p class="hero-subtitle">Enter your security credentials to access the premium<br>management dashboard.</p>
        </div>

        <!-- Admin Access Box -->
        <div class="admin-access-box">
            <label class="admin-label"><i class="bi bi-lock-fill"></i> Admin Access</label>
            <div class="password-input-wrapper">
                <input type="password" id="adminPassword" class="password-input" placeholder="Enter Security Password">
                <button class="password-toggle" type="button" onclick="togglePassword()">
                    <i class="bi bi-eye-fill"></i>
                </button>
            </div>
            <button class="enter-btn" onclick="enterDashboard()">
                <span>ENTER DASHBOARD</span>
                <i class="bi bi-arrow-right"></i>
            </button>
            <div class="encrypted-note">
                <i class="bi bi-check-circle-fill"></i> Encrypted Connection: 256-bit
            </div>
        </div>
    </div>

    <!-- Team Section -->
    <div class="team-section">
        <div style="text-align: center;">
            <div class="team-badge">The Development Team</div>
        </div>
        <div class="team-grid">
            <div class="team-card">
                <div class="team-avatar">AR</div>
                <div class="team-name">Alex Rivera</div>
                <div class="team-role">Project Manager</div>
                <div class="team-description">Orchestrates team workflows and ensures timely delivery of all sprint objectives.</div>
            </div>
            <div class="team-card">
                <div class="team-avatar">JS</div>
                <div class="team-name">Jordan Smith</div>
                <div class="team-role">Lead Developer</div>
                <div class="team-description">Architected core systems and develops the platform.</div>
            </div>
            <div class="team-card">
                <div class="team-avatar">ML</div>
                <div class="team-name">Morgan Lee</div>
                <div class="team-role">Backend Developer</div>
                <div class="team-description">Builds and maintains robust server-side infrastructure.</div>
            </div>
            <div class="team-card">
                <div class="team-avatar">CP</div>
                <div class="team-name">Casey Park</div>
                <div class="team-role">Frontend Developer</div>
                <div class="team-description">Creates responsive and seamless user interface experiences.</div>
            </div>
            <div class="team-card">
                <div class="team-avatar">TN</div>
                <div class="team-name">Taylor Nguyen</div>
                <div class="team-role">Documentation</div>
                <div class="team-description">Authored comprehensive guides and API references for the platform.</div>
            </div>
        </div>
    </div>

    <!-- Support Modal -->
    <div id="supportModal" class="support-modal">
        <div class="support-modal-content">
            <h2>Contact Us</h2>
            <p>For support and inquiries, please reach out to us:</p>
            <div class="support-email">
                GameTime@GameTime.com
            </div>
            <p style="font-size: 14px; color: #7a8a99;">We're here to help you get the most out of GameTime Management System.</p>
            <button class="modal-close-btn" onclick="closeSupportPopup()">Close</button>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function togglePassword() {
            const input = document.getElementById('adminPassword');
            const btn = event.target.closest('.password-toggle');
            const icon = btn.querySelector('i');

            if (input.type === 'password') {
                input.type = 'text';
                icon.classList.remove('bi-eye-fill');
                icon.classList.add('bi-eye-slash-fill');
            } else {
                input.type = 'password';
                icon.classList.remove('bi-eye-slash-fill');
                icon.classList.add('bi-eye-fill');
            }
        }

        function enterDashboard() {
            const password = document.getElementById('adminPassword').value;
            if (password.trim() === '') {
                alert('Please enter a password');
                return;
            }
            // Redirect to admin dashboard or login
            window.location.href = '/Admin/Dashboard';
        }

        // Allow Enter key to submit
        document.getElementById('adminPassword').addEventListener('keypress', function(e) {
            if (e.key === 'Enter') {
                enterDashboard();
            }
        });

        // Support Modal Functions
        function showSupportPopup(event) {
            event.preventDefault();
            const modal = document.getElementById('supportModal');
            modal.classList.add('show');
        }

        function closeSupportPopup() {
            const modal = document.getElementById('supportModal');
            modal.classList.remove('show');
        }

        // Close modal when clicking outside of it
        window.onclick = function(event) {
            const modal = document.getElementById('supportModal');
            if (event.target === modal) {
                modal.classList.remove('show');
            }
        }
    </script>
</body>
</html>
