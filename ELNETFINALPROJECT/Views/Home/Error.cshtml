@model ELNETFINALPROJECT.Models.ErrorViewModel
@{
    ViewData["Title"] = "Error - GameTime";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <style>
        *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            background: #0d1f2d;
            color: #ffffff;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .error-container {
            text-align: center;
            padding: 40px;
            max-width: 560px;
        }
        .error-icon {
            font-size: 64px;
            color: #ff4a4a;
            margin-bottom: 24px;
            display: block;
        }
        .error-code {
            font-size: 80px;
            font-weight: 900;
            color: #00ff88;
            line-height: 1;
            margin-bottom: 8px;
        }
        h1 {
            font-size: 24px;
            font-weight: 700;
            margin-bottom: 12px;
            color: #ffffff;
        }
        p {
            font-size: 15px;
            color: #7a8a99;
            line-height: 1.6;
            margin-bottom: 32px;
        }
        .request-id {
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 8px;
            padding: 12px 20px;
            font-family: monospace;
            font-size: 13px;
            color: #7a8a99;
            margin-bottom: 32px;
            word-break: break-all;
        }
        .back-btn {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 14px 28px;
            background: linear-gradient(135deg, #00ff88, #00cc6f);
            color: #0d1f2d;
            text-decoration: none;
            border-radius: 8px;
            font-weight: 700;
            font-size: 14px;
            letter-spacing: 1px;
            text-transform: uppercase;
            transition: all 0.2s;
        }
        .back-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 24px rgba(0,255,136,0.3);
        }
    </style>
</head>
<body>
    <div class="error-container">
        <i class="bi bi-exclamation-triangle-fill error-icon"></i>
        <div class="error-code">500</div>
        <h1>Something Went Wrong</h1>
        <p>An unexpected error occurred on the server. Our team has been notified. Please try again or return to the home page.</p>

        @if (Model?.ShowRequestId ?? false)
        {
            <div class="request-id">
                <strong>Request ID:</strong> @Model.RequestId
            </div>
        }

        <a asp-controller="Home" asp-action="Index" class="back-btn">
            <i class="bi bi-house-fill"></i> Return Home
        </a>
    </div>
</body>
</html>
