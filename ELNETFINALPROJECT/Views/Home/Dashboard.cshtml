@{
    ViewData["Title"] = "Player Management - GameTime";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

        :root {
            --bg: #0b1410;
            --bg2: #111a16;
            --bg3: #172018;
            --bg4: #1e2b20;
            --card: #141f16;
            --card2: #192218;
            --border: rgba(0,255,100,0.08);
            --border2: rgba(0,255,100,0.15);
            --green: #00e872;
            --green2: #00c460;
            --green-dim: rgba(0,232,114,0.12);
            --green-glow: rgba(0,232,114,0.06);
            --text: #e8f5ec;
            --text2: #8aaa90;
            --text3: #506055;
            --red: #ff4d4d;
            --amber: #ffaa00;
            --blue: #4d9fff;
            --sidebar-w: 220px;
        }

        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--bg);
            color: var(--text);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* TOP NAV */
        .topnav {
            height: 52px;
            background: var(--bg2);
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            padding: 0 20px;
            gap: 16px;
            position: sticky;
            top: 0;
            z-index: 100;
        }
        .topnav-brand {
            display: flex;
            align-items: center;
            gap: 8px;
            font-weight: 700;
            font-size: 15px;
            letter-spacing: 0.5px;
            text-decoration: none;
            color: var(--text);
        }
        .brand-icon {
            width: 28px; height: 28px;
            background: var(--green);
            border-radius: 7px;
            display: flex; align-items: center; justify-content: center;
        }
        .brand-icon svg { color: #0b1410; }
        .brand-label span { color: var(--green); }
        .admin-pill {
            font-size: 10px; font-weight: 600;
            background: var(--green-dim);
            color: var(--green);
            border: 1px solid var(--border2);
            border-radius: 4px;
            padding: 2px 7px;
            letter-spacing: 1px;
            text-transform: uppercase;
        }
        .topnav-search {
            flex: 1;
            max-width: 320px;
            margin-left: 24px;
            position: relative;
        }
        .topnav-search input {
            width: 100%;
            background: var(--bg3);
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: 7px 12px 7px 34px;
            font-size: 13px;
            color: var(--text);
            font-family: 'DM Sans', sans-serif;
            outline: none;
        }
        .topnav-search input::placeholder { color: var(--text3); }
        .topnav-search input:focus { border-color: var(--border2); }
        .search-icon {
            position: absolute; left: 10px; top: 50%;
            transform: translateY(-50%);
            color: var(--text3); font-size: 14px;
        }
        .topnav-right {
            margin-left: auto;
            display: flex;
            align-items: center;
            gap: 14px;
        }
        .status-pill {
            display: flex; align-items: center; gap: 6px;
            background: var(--green-dim);
            border: 1px solid var(--border2);
            border-radius: 20px;
            padding: 5px 12px;
            font-size: 12px;
            font-weight: 500;
            color: var(--green);
        }
        .status-dot {
            width: 7px; height: 7px;
            background: var(--green);
            border-radius: 50%;
            animation: pulse 2s infinite;
        }
        @@keyframes pulse { 0%,100%{opacity:1;} 50%{opacity:0.5;} }
        .topnav-icon-btn {
            width: 34px; height: 34px;
            background: var(--bg3);
            border: 1px solid var(--border);
            border-radius: 8px;
            display: flex; align-items: center; justify-content: center;
            cursor: pointer; color: var(--text2);
            font-size: 15px;
            position: relative;
            transition: border-color 0.2s;
        }
        .topnav-icon-btn:hover { border-color: var(--border2); color: var(--text); }
        .notif-badge {
            position: absolute; top: -4px; right: -4px;
            width: 16px; height: 16px;
            background: var(--red);
            border-radius: 50%;
            font-size: 9px;
            display: flex; align-items: center; justify-content: center;
            font-weight: 700;
            color: #fff;
        }
        .user-chip {
            display: flex; align-items: center; gap: 8px;
            background: var(--bg3);
            border: 1px solid var(--border);
            border-radius: 10px;
            padding: 5px 10px 5px 6px;
            cursor: pointer;
        }
        .user-avatar {
            width: 26px; height: 26px;
            background: linear-gradient(135deg, var(--green), var(--green2));
            border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            font-size: 11px; font-weight: 700; color: #0b1410;
        }
        .user-info { line-height: 1.2; }
        .user-name { font-size: 12px; font-weight: 600; }
        .user-role { font-size: 10px; color: var(--text3); }

        /* LAYOUT */
        .app-body {
            display: flex;
            flex: 1;
            overflow: hidden;
            height: calc(100vh - 52px);
        }

        /* SIDEBAR */
        .sidebar {
            width: var(--sidebar-w);
            background: var(--bg2);
            border-right: 1px solid var(--border);
            padding: 20px 12px;
            display: flex;
            flex-direction: column;
            gap: 8px;
        }
        .sidebar-section-label {
            font-size: 10px;
            font-weight: 600;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            color: var(--text3);
            padding: 4px 8px;
            margin-top: 8px;
        }
        .sidebar-item {
            display: block; box-sizing: border-box; width: 100%;
            display: flex; align-items: center; gap: 10px;
            padding: 8px 10px;
            border-radius: 8px;
            cursor: pointer;
            font-size: 13px;
            font-weight: 500;
            color: var(--text2);
            text-decoration: none;
            transition: all 0.15s;
            border: 1px solid transparent;
        }
        .sidebar-item:hover { background: var(--bg3); color: var(--text); }
        .sidebar-item.active {
            background: var(--green-dim);
            color: var(--green);
            border-color: var(--border2);
        }
        .sidebar-item i { font-size: 15px; width: 18px; text-align: center; }
        .sidebar-badge {
            margin-left: auto;
            background: var(--bg4);
            color: var(--text2);
            font-size: 11px;
            padding: 1px 7px;
            border-radius: 10px;
            font-weight: 500;
        }
        .sidebar-item.active .sidebar-badge {
            background: rgba(0,232,114,0.2);
            color: var(--green);
        }

        .sidebar-bottom {
            margin-top: auto;
            border-top: 1px solid var(--border);
            padding-top: 14px;
            display: flex; flex-direction: column; gap: 4px;
        }
        .station-occ {
            padding: 10px;
            background: var(--bg3);
            border-radius: 8px;
            border: 1px solid var(--border);
            margin-bottom: 8px;
        }
        .occ-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 6px; }
        .occ-label { font-size: 11px; color: var(--text3); }
        .occ-count { font-size: 12px; font-weight: 600; }
        .occ-bar { height: 4px; background: var(--bg4); border-radius: 2px; overflow: hidden; }
        .occ-fill { height: 100%; background: var(--green); border-radius: 2px; width: 70%; }
        .occ-sub { font-size: 10px; color: var(--text3); margin-top: 5px; }
        .server-load {
            display: flex; align-items: center; justify-content: space-between;
            padding: 8px 10px;
            background: var(--bg3);
            border-radius: 8px;
            border: 1px solid var(--border);
        }
        .server-left { display: flex; align-items: center; gap: 8px; }
        .server-icon { font-size: 14px; color: var(--green); }
        .server-info { line-height: 1.3; }
        .server-title { font-size: 11px; color: var(--text2); font-weight: 500; }
        .server-sub { font-size: 10px; color: var(--text3); }
        .server-dot { width: 8px; height: 8px; background: var(--green); border-radius: 50%; }

        /* MAIN */
        .main {
            flex: 1;
            overflow-y: auto;
            padding: 24px;
            display: flex;
            gap: 20px;
        }
        .main-left { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 20px; }
        .main-right { width: 280px; flex-shrink: 0; }

        /* BREADCRUMB + HEADER */
        .breadcrumb-row {
            display: flex; align-items: center; gap: 6px;
            font-size: 12px; color: var(--text3);
            margin-bottom: 6px;
        }
        .breadcrumb-row i { font-size: 11px; }
        .breadcrumb-row a { color: var(--text3); text-decoration: none; }
        .breadcrumb-row a:hover { color: var(--text2); }
        .page-header {
            display: flex; align-items: flex-start; justify-content: space-between;
            margin-bottom: 4px;
        }
        .page-title { font-size: 24px; font-weight: 700; letter-spacing: -0.5px; }
        .page-sub { font-size: 13px; color: var(--text3); margin-top: 2px; }
        .header-actions { display: flex; align-items: center; gap: 10px; }
        .btn { 
            display: flex; align-items: center; gap: 6px;
            padding: 8px 14px;
            border-radius: 8px;
            font-size: 13px;
            font-weight: 500;
            cursor: pointer;
            border: none;
            font-family: 'DM Sans', sans-serif;
            transition: all 0.15s;
        }
        .btn-ghost {
            background: var(--bg3);
            color: var(--text2);
            border: 1px solid var(--border);
        }
        .btn-ghost:hover { border-color: var(--border2); color: var(--text); }
        .btn-primary {
            background: var(--green);
            color: #0b1410;
            font-weight: 600;
        }
        .btn-primary:hover { background: var(--green2); }
        .btn i { font-size: 14px; }

        /* STAT CARDS */
        .stat-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 14px;
        }
        .stat-card {
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 16px;
            position: relative;
            overflow: hidden;
        }
        .stat-badge {
            font-size: 9px; font-weight: 700;
            letter-spacing: 1.2px;
            text-transform: uppercase;
            padding: 2px 7px;
            border-radius: 4px;
            display: inline-block;
            margin-bottom: 10px;
        }
        .badge-live { background: rgba(0,232,114,0.15); color: var(--green); border: 1px solid rgba(0,232,114,0.3); }
        .badge-stations { background: rgba(77,159,255,0.15); color: var(--blue); border: 1px solid rgba(77,159,255,0.3); }
        .badge-today { background: rgba(255,170,0,0.15); color: var(--amber); border: 1px solid rgba(255,170,0,0.3); }
        .badge-revenue { background: rgba(255,77,77,0.15); color: var(--red); border: 1px solid rgba(255,77,77,0.3); }
        .stat-num {
            font-size: 38px;
            font-weight: 700;
            line-height: 1;
            letter-spacing: -1px;
            margin-bottom: 6px;
        }
        .stat-label { font-size: 11px; color: var(--text3); font-weight: 500; letter-spacing: 0.5px; text-transform: uppercase; }
        .stat-change {
            display: flex; align-items: center; gap: 4px;
            font-size: 11px;
            margin-top: 8px;
        }
        .stat-change.up { color: var(--green); }
        .stat-change.up-amber { color: var(--amber); }
        .stat-icon {
            position: absolute; top: 14px; right: 14px;
            width: 32px; height: 32px;
            border-radius: 8px;
            display: flex; align-items: center; justify-content: center;
            font-size: 16px;
        }

        /* STATIONS GRID */
        .section-header {
            display: flex; align-items: center; justify-content: space-between;
            margin-bottom: 14px;
        }
        .section-title {
            display: flex; align-items: center; gap: 8px;
            font-size: 14px; font-weight: 600;
        }
        .section-title i { color: var(--green); font-size: 15px; }
        .section-sub { font-size: 11px; color: var(--text3); font-weight: 400; margin-left: 4px; }
        .legend { display: flex; align-items: center; gap: 12px; }
        .legend-item { display: flex; align-items: center; gap: 5px; font-size: 11px; color: var(--text3); }
        .legend-dot { width: 7px; height: 7px; border-radius: 50%; }

        .stations-panel {
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 18px;
        }
        .stations-grid {
            display: grid;
            grid-template-columns: repeat(7, 1fr);
            gap: 12px;
        }
        .station-card {
            background: var(--bg3);
            border: 1px solid var(--border);
            border-radius: 10px;
            padding: 12px;
            display: flex; flex-direction: column; gap: 8px;
            transition: border-color 0.2s;
            cursor: pointer;
        }
        .station-card:hover { border-color: var(--border2); }
        .station-card.offline { opacity: 0.55; }
        .station-top {
            display: flex; align-items: center; justify-content: space-between;
        }
        .station-num { font-size: 11px; font-weight: 600; color: var(--text3); }
        .station-dot { width: 7px; height: 7px; border-radius: 50%; }
        .dot-green { background: var(--green); }
        .dot-amber { background: var(--amber); }
        .dot-red { background: var(--red); }
        .dot-gray { background: var(--text3); }
        .station-avatar {
            width: 48px; height: 48px;
            border-radius: 10px;
            background: var(--bg4);
            display: flex; align-items: center; justify-content: center;
            color: var(--green);
            border: 1px solid var(--border2);
            margin: 0 auto;
        }
        .station-avatar img { width: 100%; height: 100%; object-fit: cover; }
        .station-username { font-size: 12px; font-weight: 600; line-height: 1.2; }
        .station-game { font-size: 10px; color: var(--text3); }
        .station-time {
            display: flex; align-items: center; gap: 4px;
            font-size: 11px; color: var(--text2);
            font-family: 'JetBrains Mono', monospace;
        }
        .station-time i { font-size: 10px; color: var(--green); }
        .station-btn {
            width: 100%;
            padding: 5px;
            border-radius: 6px;
            font-size: 11px;
            font-weight: 600;
            cursor: pointer;
            border: none;
            font-family: 'DM Sans', sans-serif;
            transition: all 0.15s;
        }
        .station-btn.manage { background: var(--green-dim); color: var(--green); border: 1px solid var(--border2); }
        .station-btn.manage:hover { background: rgba(0,232,114,0.2); }
        .station-btn.assign { background: var(--bg4); color: var(--text3); border: 1px solid var(--border); }
        .station-btn.offline-btn { background: rgba(255,77,77,0.1); color: var(--red); border: 1px solid rgba(255,77,77,0.2); }
        .station-status-text { font-size: 11px; color: var(--text3); text-align: center; }

        /* PC STATUS CARDS (Dashboard) */
        .pc-status-card {
            background: var(--bg3);
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: 10px 8px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 6px;
            text-align: center;
            transition: border-color 0.2s;
            min-height: 130px;
        }
        .pc-status-card:hover { border-color: var(--border2); }
        .pc-status-card.offline { opacity: 0.55; }
        .pc-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            width: 100%;
            padding: 0 4px;
        }
        .pc-number { font-size: 10px; font-weight: 600; color: var(--text3); }
        .pc-dot { width: 6px; height: 6px; border-radius: 50%; }
        .pc-dot.dot-green { background: var(--green); }
        .pc-dot.dot-amber { background: var(--amber); }
        .pc-dot.dot-red { background: var(--red); }
        .pc-dot.dot-gray { background: var(--text3); }
        .pc-icon {
            font-size: 24px;
            color: var(--green);
            margin: 2px 0;
        }
        .pc-status {
            font-size: 10px;
            font-weight: 600;
            color: var(--text2);
            line-height: 1.2;
        }
        .pc-player {
            font-size: 9px;
            color: var(--text3);
            line-height: 1.2;
        }
        .pc-time {
            font-size: 9px;
            color: var(--text3);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 2px;
        }

        /* PLAYER TABLE */
        .player-table-panel {
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: 12px;
            overflow: hidden;
        }
        .table-header {
            display: flex; align-items: center; justify-content: space-between;
            padding: 16px 18px;
            border-bottom: 1px solid var(--border);
        }
        .table-tabs {
            display: flex; gap: 4px;
            padding: 4px;
            background: var(--bg3);
            border-radius: 8px;
            margin-top: 10px;
            margin-left: 18px;
            margin-right: 18px;
        }
        .tab {
            padding: 6px 14px;
            border-radius: 6px;
            font-size: 12px;
            font-weight: 500;
            cursor: pointer;
            color: var(--text3);
            transition: all 0.15s;
        }
        .tab.active { background: var(--bg4); color: var(--text); }
        .tab:hover:not(.active) { color: var(--text2); }
        .table-actions { display: flex; gap: 8px; }
        .table-search {
            position: relative;
        }
        .table-search input {
            background: var(--bg3);
            border: 1px solid var(--border);
            border-radius: 7px;
            padding: 6px 10px 6px 30px;
            font-size: 12px;
            color: var(--text);
            font-family: 'DM Sans', sans-serif;
            outline: none;
            width: 180px;
        }
        .table-search input::placeholder { color: var(--text3); }
        .table-search i { position: absolute; left: 9px; top: 50%; transform: translateY(-50%); font-size: 12px; color: var(--text3); }
        table { width: 100%; border-collapse: collapse; }
        thead th {
            padding: 10px 18px;
            text-align: left;
            font-size: 10px;
            font-weight: 600;
            letter-spacing: 0.8px;
            text-transform: uppercase;
            color: var(--text3);
            border-bottom: 1px solid var(--border);
        }
        tbody tr {
            border-bottom: 1px solid var(--border);
            transition: background 0.1s;
        }
        tbody tr:hover { background: var(--bg3); }
        tbody tr:last-child { border-bottom: none; }
        td { padding: 12px 18px; font-size: 13px; }
        .player-cell { display: flex; align-items: center; gap: 10px; }
        .player-av {
            width: 36px; height: 36px;
            border-radius: 50%;
            background: var(--bg4);
            display: flex; align-items: center; justify-content: center;
            font-size: 13px; font-weight: 700;
            color: var(--green);
            border: 1px solid var(--border2);
            overflow: hidden; flex-shrink: 0;
        }
        .player-av img { width: 100%; height: 100%; object-fit: cover; }
        .player-pname { font-size: 13px; font-weight: 600; display: flex; align-items: center; gap: 5px; }
        .player-email { font-size: 11px; color: var(--text3); }
        .vip-badge {
            font-size: 9px; font-weight: 700;
            background: rgba(255,170,0,0.15);
            color: var(--amber);
            border: 1px solid rgba(255,170,0,0.3);
            padding: 1px 5px; border-radius: 3px;
            letter-spacing: 0.5px;
        }
        .balance-cell { font-family: 'JetBrains Mono', monospace; font-size: 12px; color: var(--green); font-weight: 500; }
        .status-active {
            display: inline-flex; align-items: center; gap: 5px;
            background: var(--green-dim);
            color: var(--green);
            border: 1px solid var(--border2);
            padding: 3px 8px;
            border-radius: 5px;
            font-size: 11px;
            font-weight: 500;
        }
        .status-active::before { content: ''; width: 6px; height: 6px; background: var(--green); border-radius: 50%; display: block; }
        .actions-cell { display: flex; gap: 6px; }
        .action-btn {
            width: 28px; height: 28px;
            border-radius: 6px;
            border: 1px solid var(--border);
            background: var(--bg3);
            display: flex; align-items: center; justify-content: center;
            cursor: pointer; color: var(--text3);
            font-size: 13px;
            transition: all 0.15s;
        }
        .action-btn:hover { border-color: var(--border2); color: var(--text); }
        .action-btn.danger:hover { border-color: rgba(255,77,77,0.4); color: var(--red); background: rgba(255,77,77,0.08); }

        /* RIGHT PANEL - PLAYER DETAIL */
        .detail-panel {
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: 12px;
            overflow: hidden;
        }
        .detail-header {
            padding: 14px 16px;
            border-bottom: 1px solid var(--border);
            display: flex; align-items: center; gap: 8px;
            background: var(--bg3);
        }
        .detail-header i { color: var(--green); font-size: 14px; }
        .detail-header-title { font-size: 13px; font-weight: 600; }
        .detail-header-sub { font-size: 11px; color: var(--text3); }
        .detail-body { padding: 16px; display: flex; flex-direction: column; gap: 16px; }

        /* COMPUTER ICON SECTION */
        .computer-section {
            background: var(--bg3);
            border: 2px dashed var(--border2);
            border-radius: 10px;
            padding: 24px 16px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 10px;
            text-align: center;
            cursor: pointer;
            transition: all 0.2s;
        }
        .computer-section:hover { border-color: var(--green); background: var(--green-dim); }
        .computer-icon-wrap {
            width: 64px; height: 64px;
            background: var(--green-dim);
            border: 1px solid var(--border2);
            border-radius: 14px;
            display: flex; align-items: center; justify-content: center;
        }
        .computer-icon-wrap i { font-size: 30px; color: var(--green); }
        .computer-label { font-size: 12px; font-weight: 600; color: var(--text2); }
        .computer-sub { font-size: 10px; color: var(--text3); }

        .detail-section-label {
            font-size: 10px; font-weight: 700;
            letter-spacing: 1.2px;
            text-transform: uppercase;
            color: var(--text3);
            margin-bottom: 10px;
        }
        .detail-field { margin-bottom: 10px; }
        .field-label {
            font-size: 10px; color: var(--text3);
            text-transform: uppercase; letter-spacing: 0.8px;
            margin-bottom: 4px;
        }
        .field-value {
            display: flex; align-items: center; justify-content: space-between;
            background: var(--bg3);
            border: 1px solid var(--border);
            border-radius: 7px;
            padding: 8px 10px;
            font-size: 13px;
        }
        .field-icon { font-size: 12px; color: var(--text3); cursor: pointer; }
        .field-icon:hover { color: var(--green); }
        .field-value-inner { display: flex; align-items: center; gap: 6px; }
        .field-value-inner i { color: var(--text3); font-size: 12px; }
        .detail-row {
            display: grid; grid-template-columns: 1fr 1fr;
            gap: 10px;
        }

        .session-panel {
            background: var(--bg3);
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: 12px;
        }
        .session-row {
            display: flex; justify-content: space-between;
            font-size: 12px;
            margin-bottom: 6px;
        }
        .session-row-label { color: var(--text3); }
        .session-row-val { font-weight: 500; font-family: 'JetBrains Mono', monospace; font-size: 11px; }
        .session-row-val.green { color: var(--green); }
        .time-bar { height: 4px; background: var(--bg4); border-radius: 2px; margin-top: 8px; overflow: hidden; }
        .time-fill { height: 100%; background: var(--green); border-radius: 2px; width: 78%; }

        .detail-actions { display: flex; flex-direction: column; gap: 8px; }
        .btn-save {
            width: 100%;
            padding: 10px;
            background: var(--green);
            color: #0b1410;
            border: none;
            border-radius: 8px;
            font-size: 13px;
            font-weight: 700;
            cursor: pointer;
            font-family: 'DM Sans', sans-serif;
            display: flex; align-items: center; justify-content: center; gap: 6px;
            transition: background 0.15s;
        }
        .btn-save:hover { background: var(--green2); }
        .detail-btn-row { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
        .btn-add-time {
            padding: 8px;
            background: var(--green-dim);
            color: var(--green);
            border: 1px solid var(--border2);
            border-radius: 7px;
            font-size: 12px; font-weight: 600;
            cursor: pointer;
            font-family: 'DM Sans', sans-serif;
            display: flex; align-items: center; justify-content: center; gap: 5px;
        }
        .btn-end-session {
            padding: 8px;
            background: rgba(255,77,77,0.1);
            color: var(--red);
            border: 1px solid rgba(255,77,77,0.2);
            border-radius: 7px;
            font-size: 12px; font-weight: 600;
            cursor: pointer;
            font-family: 'DM Sans', sans-serif;
            display: flex; align-items: center; justify-content: center; gap: 5px;
        }
    </style>
</head>
<body>

<!-- TOP NAV -->
<partial name="_Header" />

<div class="app-body">
    <!-- SIDEBAR -->
    <partial name="_Sidebar" />

    <!-- MAIN CONTENT -->
    <main class="main">
        <div class="main-left">
            <!-- Page Header -->
            <div>
                <div class="breadcrumb-row">
                    <i class="bi bi-house"></i>
                    <a href="#">Dashboard</a>
                    <i class="bi bi-chevron-right"></i>
                    <span style="color:var(--text2);">Players</span>
                </div>
                <div class="page-header">
                    <div>
                        <h1 class="page-title">Player Management</h1>
                        <p class="page-sub">Monitor stations, manage players & sessions in real-time.</p>
                    </div>
                    <div class="header-actions">
                        <button class="btn btn-ghost"><i class="bi bi-clock"></i> Live</button>
                        <button class="btn btn-ghost"><i class="bi bi-funnel"></i> Filters</button>
                        <button class="btn btn-primary" onclick="openRegisterModal()"><i class="bi bi-person-plus-fill"></i> Add Player</button>
                    </div>
                </div>
            </div>

            <!-- Stat Cards -->
            <div class="stat-grid">
                <div class="stat-card">
                    <div class="stat-badge badge-live">Live</div>
                    <div class="stat-icon" style="background:var(--green-dim);"><i class="bi bi-people-fill" style="color:var(--green);font-size:15px;"></i></div>
                    <div class="stat-num">—</div>
                    <div class="stat-label">Players Online</div>
                    <div class="stat-change up">—</div>
                </div>
                <div class="stat-card">
                    <div class="stat-badge badge-stations">Stations</div>
                    <div class="stat-icon" style="background:rgba(77,159,255,0.1);"><i class="bi bi-display" style="color:var(--blue);font-size:15px;"></i></div>
                    <div class="stat-num" style="color:var(--blue);">—</div>
                    <div class="stat-label">Available Stations</div>
                    <div class="stat-change" style="color:var(--text3);">—</div>
                </div>
                <div class="stat-card">
                    <div class="stat-badge badge-today">Today</div>
                    <div class="stat-icon" style="background:rgba(255,170,0,0.1);"><i class="bi bi-lightning-fill" style="color:var(--amber);font-size:15px;"></i></div>
                    <div class="stat-num" style="color:var(--amber);">—</div>
                    <div class="stat-label">Active Sessions</div>
                    <div class="stat-change up-amber">—</div>
                </div>
                <div class="stat-card">
                    <div class="stat-badge badge-revenue">Revenue</div>
                    <div class="stat-icon" style="background:rgba(255,77,77,0.1);"><i class="bi bi-currency-dollar" style="color:var(--red);font-size:15px;"></i></div>
                    <div class="stat-num" style="color:var(--green);">—</div>
                    <div class="stat-label">Earned Today</div>
                    <div class="stat-change up">—</div>
                </div>
            </div>

            <!-- Gaming Stations -->
            <div class="stations-panel">
                <div class="section-header">
                    <div class="section-title">
                        <i class="bi bi-display-fill"></i>
                        Gaming Stations
                        <span class="section-sub">Real-time PC status and session monitoring</span>
                    </div>
                    <div class="legend">
                        <div class="legend-item"><div class="legend-dot dot-green"></div> Active</div>
                        <div class="legend-item"><div class="legend-dot dot-amber"></div> Occupied</div>
                        <div class="legend-item"><div class="legend-dot dot-red"></div> Offline</div>
                        <div class="legend-item"><div class="legend-dot" style="background:var(--text3);"></div> Available</div>
                    </div>
                </div>
                <div class="stations-grid" id="pcGrid">
                    <!-- Stations loaded via JavaScript -->
                </div>
            </div>

            <!-- Player Management Table -->
            <div class="player-table-panel">
                <div class="table-header">
                    <div>
                        <div class="section-title"><i class="bi bi-table"></i> Player Management</div>
                        <div style="font-size:11px;color:var(--text3);margin-top:2px;">Full registry of all registered players</div>
                    </div>
                    <div class="table-actions">
                        <div class="table-search">
                            <i class="bi bi-search"></i>
                            <input type="text" placeholder="Search players..." id="playerSearchInput" />
                        </div>
                        <button class="btn btn-ghost" style="padding:6px 12px;font-size:12px;"><i class="bi bi-funnel"></i> Filter</button>
                        <button class="btn btn-ghost" style="padding:6px 12px;font-size:12px;"><i class="bi bi-download"></i> Export</button>
                    </div>
                </div>
                <div class="table-tabs">
                    <div class="tab active" onclick="filterPlayers('all')">All Players</div>
                    <div class="tab" onclick="filterPlayers('online')">Online Now</div>
                    <div class="tab" onclick="filterPlayers('verified')">Verified</div>
                    <div class="tab" onclick="filterPlayers('inactive')">Inactive</div>
                </div>
                <div class="table-scroll">
                    <table class="data-table" id="playersTable">
                        <thead>
                            <tr>
                                <th>Player</th>
                                <th>Email</th>
                                <th>Status</th>
                                <th>Balance</th>
                                <th>Rank</th>
                                <th>Sessions</th>
                                <th>Joined</th>
                                <th>Last Seen</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <!-- Players loaded via JavaScript -->
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- RIGHT PANEL -->
        <aside class="main-right">
            <div class="detail-panel">
                <div class="detail-header">
                    <i class="bi bi-person-vcard-fill"></i>
                    <div>
                        <div class="detail-header-title">Player Detail</div>
                        <div class="detail-header-sub">Edit profile & manage session</div>
                    </div>
                </div>
                <div class="detail-body">

                    <!-- COMPUTER ICON (replaces profile picture upload) -->
                    <div>
                        <div class="detail-section-label">Station Assignment</div>
                        <div class="computer-section">
                            <div class="computer-icon-wrap">
                                <i class="bi bi-display-fill"></i>
                            </div>
                            <div class="computer-label">—</div>
                            <div class="computer-sub">Click to reassign station</div>
                        </div>
                    </div>

                    <!-- Player Info -->
                    <div>
                        <div class="detail-section-label">Player Info</div>
                        <div class="detail-field">
                            <div class="field-label">Username</div>
                            <div class="field-value">
                                <div class="field-value-inner"><i class="bi bi-person"></i> —</div>
                                <i class="bi bi-pencil field-icon"></i>
                            </div>
                        </div>
                        <div class="detail-field">
                            <div class="field-label">Email</div>
                            <div class="field-value">
                                <div class="field-value-inner"><i class="bi bi-envelope"></i> —</div>
                            </div>
                        </div>
                        <div class="detail-row">
                            <div class="detail-field">
                                <div class="field-label">Balance</div>
                                <div class="field-value" style="color:var(--green);font-family:'JetBrains Mono',monospace;font-size:12px;">
                                    —
                                </div>
                            </div>
                            <div class="detail-field">
                                <div class="field-label">Station</div>
                                <div class="field-value" style="font-size:12px;">
                                    <div class="field-value-inner"><i class="bi bi-display"></i> —</div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Current Session -->
                    <div>
                        <div class="detail-section-label">Current Session</div>
                        <div class="session-panel">
                            <div class="session-row">
                                <span class="session-row-label">Game</span>
                                <span class="session-row-val">—</span>
                            </div>
                            <div class="session-row">
                                <span class="session-row-label">Time Elapsed</span>
                                <span class="session-row-val green">—</span>
                            </div>
                            <div class="session-row" style="margin-bottom:0;">
                                <span class="session-row-label">Time Remaining</span>
                                <span class="session-row-val">—</span>
                            </div>
                            <div class="time-bar"><div class="time-fill"></div></div>
                        </div>
                    </div>

                    <!-- Actions -->
                    <div class="detail-actions">
                        <button class="btn-save"><i class="bi bi-floppy2-fill"></i> Save Changes</button>
                        <div class="detail-btn-row">
                            <button class="btn-add-time"><i class="bi bi-plus-circle"></i> Add Time</button>
                            <button class="btn-end-session"><i class="bi bi-stop-circle"></i> End Session</button>
                        </div>
                    </div>

                </div>
            </div>
        </aside>
    </main>
</div>

</div>

<partial name="_RegisterModal" />

<script>
    // Admin Dashboard - Real Data Loading & Management
    let allPlayers = [];
    let currentFilter = 'all';
    let autoRefreshInterval = null;

    /**
     * Initialize dashboard - Load all data and start auto-refresh
     */
    async function initDashboard() {
        await loadAdminStats();
        await loadStationsStatus();
        await loadPlayersTable();
        
        // Auto-refresh every 30 seconds
        if (autoRefreshInterval) clearInterval(autoRefreshInterval);
        autoRefreshInterval = setInterval(() => {
            loadAdminStats();
            loadStationsStatus();
            loadPlayersTable();
        }, 30000);
    }

    /**
     * Load admin statistics and populate stat cards
     */
    async function loadAdminStats() {
        try {
            const response = await fetch('/Home/GetAdminStats');
            if (!response.ok) throw new Error('Failed to load stats');
            
            const data = await response.json();
            if (data.success) {
                const cards = document.querySelectorAll('.stat-card');
                
                // Players Online
                cards[0].querySelector('.stat-num').textContent = data.onlinePlayers;
                
                // Available Stations
                cards[1].querySelector('.stat-num').textContent = data.availableStations ?? 0;
                
                // Active Sessions
                cards[2].querySelector('.stat-num').textContent = data.activeSessions || 0;
                
                // Today's Revenue
                cards[3].querySelector('.stat-num').textContent = '₱' + (data.todayEarnings || 0).toFixed(2);
            }
        } catch (error) {
            console.error('Error loading admin stats:', error);
        }
    }

    /**
     * Load gaming stations status
     */
    async function loadStationsStatus() {
        try {
            const response = await fetch('/Home/GetStationsStatus');
            if (!response.ok) throw new Error('Failed to load stations');
            
            const data = await response.json();
            if (data.success && data.stations) {
                const grid = document.getElementById('pcGrid');
                
                grid.innerHTML = data.stations.map(station => {
                    const isActive = station.status === 'active';
                    const isUnavailable = station.status === 'unavailable';
                    const isAvailable = station.status === 'available';
                    const cardClass = isUnavailable ? 'unavailable' : isActive ? 'occupied' : isAvailable ? 'available' : 'offline';
                    const dotClass = isUnavailable ? 'dot-red' : isActive ? 'dot-amber' : isAvailable ? 'dot-green' : 'dot-gray';
                    const labelText = isUnavailable ? 'Unavailable' : isActive ? 'Active' : isAvailable ? 'Available' : 'Offline';
                    const sessionText = station.sessionTime || '—';

                    return `
                    <div class="station-card ${cardClass}">
                        <div class="station-top">
                            <span class="station-num">PC ${station.stationNumber}</span>
                            <span class="station-dot ${dotClass}"></span>
                        </div>
                        <div class="station-avatar" style="background: var(--bg4);">
                            <i class="bi bi-display" style="font-size: 24px; color: var(--green);"></i>
                        </div>
                        <div style="text-align: center; font-size: 11px; color: var(--text3);">
                            ${isActive ? `
                                <div class="station-username">${station.playerName || 'Active'}</div>
                                <div class="station-game">${station.currentGame || 'Gaming'}</div>
                                <div class="station-time"><i class="bi bi-hourglass-split"></i> ${sessionText}</div>
                            ` : `
                                <div class="station-status-text">${labelText}</div>
                            `}
                        </div>
                    </div>
                `;
                }).join('');
            }
        } catch (error) {
            console.error('Error loading stations:', error);
        }
    }

    /**
     * Calculate player rank
     */
    function getPlayerRank(totalSessions, joinedDate) {
        const accountAgeDays = Math.floor((Date.now() - new Date(joinedDate).getTime()) / (1000 * 60 * 60 * 24));
        
        if (totalSessions >= 100 && accountAgeDays >= 90) return 'Legend';
        if (totalSessions >= 80 && accountAgeDays >= 60) return 'Diamond';
        if (totalSessions >= 60 && accountAgeDays >= 30) return 'Platinum';
        if (totalSessions >= 40 && accountAgeDays >= 14) return 'Gold';
        if (totalSessions >= 20 && accountAgeDays >= 7) return 'Silver';
        return 'Bronze';
    }

    /**
     * Load players table with real data
     */
    async function loadPlayersTable() {
        try {
            const response = await fetch('/Home/GetPlayers');
            if (!response.ok) throw new Error('Failed to load players');
            
            const data = await response.json();
            allPlayers = data.success ? data.players : data;
            renderPlayersTable(allPlayers);
        } catch (error) {
            console.error('Error loading players:', error);
        }
    }

    /**
     * Render players in table based on current filter
     */
    function renderPlayersTable(players) {
        const tbody = document.querySelector('#playersTable tbody');
        let filtered = players;

        // Apply current filter
        switch (currentFilter) {
            case 'online':
                filtered = players.filter(p => p.status === 'Online');
                break;
            case 'verified':
                filtered = players.filter(p => p.isVerified);
                break;
            case 'inactive':
                filtered = players.filter(p => p.status === 'Offline');
                break;
            default:
                filtered = players;
        }

        if (filtered.length === 0) {
            tbody.innerHTML = `<tr><td colspan="9" style="text-align: center; padding: 30px; color: var(--text3);">
                <i class="bi bi-inbox" style="font-size: 24px; display: block; margin-bottom: 10px;"></i>
                No players found.
            </td></tr>`;
            return;
        }

        tbody.innerHTML = filtered.map(player => {
            const rank = getPlayerRank(player.totalSessions || 0, player.registeredDate);
            const lastSeen = player.lastLogin ? new Date(player.lastLogin).toLocaleDateString('en-PH') : '—';
            const joined = new Date(player.registeredDate).toLocaleDateString('en-PH');

            return `
                <tr>
                    <td>
                        <div class="player-cell">
                            <div class="player-av">${player.username.slice(0, 2).toUpperCase()}</div>
                            <div>
                                <div class="player-pname">
                                    ${player.username}
                                    ${player.isVerified ? '<span class="vip-badge">VERIFIED</span>' : ''}
                                </div>
                                <div class="player-email">${player.email}</div>
                            </div>
                        </div>
                    </td>
                    <td style="font-size: 12px; color: var(--text3);">${player.email}</td>
                    <td>
                        <span class="status-active" style="background: ${player.status === 'Online' ? 'var(--green-dim)' : 'rgba(255,77,77,0.1)'}; color: ${player.status === 'Online' ? 'var(--green)' : 'var(--red)'}; border-color: ${player.status === 'Online' ? 'var(--border2)' : 'rgba(255,77,77,0.2)'};">
                            ${player.status === 'Online' ? '' : ''}${player.status}
                        </span>
                    </td>
                    <td class="balance-cell">₱${(player.balance || 0).toFixed(2)}</td>
                    <td style="font-size: 12px; font-weight: 600; color: var(--green);">${rank}</td>
                    <td style="font-size: 12px; color: var(--text3);">${player.totalSessions || 0}</td>
                    <td style="font-size: 12px; color: var(--text3);">${joined}</td>
                    <td style="font-size: 12px; color: var(--text3);">${lastSeen}</td>
                    <td>
                        <div class="actions-cell">
                            <button class="action-btn" title="Edit" onclick="editPlayerDetail(${player.id})">
                                <i class="bi bi-pencil"></i>
                            </button>
                            <button class="action-btn" title="Top-up" onclick="topUpPlayerBalance(${player.id})">
                                <i class="bi bi-plus-circle"></i>
                            </button>
                            <button class="action-btn danger" title="Delete" onclick="deletePlayer(${player.id})">
                                <i class="bi bi-trash"></i>
                            </button>
                        </div>
                    </td>
                </tr>
            `;
        }).join('');
    }

    /**
     * Filter players by status
     */
    function filterPlayers(filter) {
        currentFilter = filter;
        
        // Update active tab
        document.querySelectorAll('.tab').forEach(tab => {
            tab.classList.remove('active');
        });
        event.target.classList.add('active');
        
        renderPlayersTable(allPlayers);
    }

    /**
     * Delete a player
     */
    async function deletePlayer(playerId) {
        if (!confirm('Are you sure you want to delete this player?')) return;
        
        try {
            const response = await fetch(`/Home/DeletePlayer?playerId=${playerId}`, {
                method: 'DELETE'
            });
            
            if (response.ok) {
                alert('Player deleted successfully');
                await loadPlayersTable();
            } else {
                alert('Failed to delete player');
            }
        } catch (error) {
            console.error('Error deleting player:', error);
            alert('Error deleting player');
        }
    }

    /**
     * Top-up player balance
     */
    async function topUpPlayerBalance(playerId) {
        const amount = prompt('Enter top-up amount (₱):');
        if (amount === null) return;
        
        const parsedAmount = parseFloat(amount);
        if (isNaN(parsedAmount) || parsedAmount <= 0) {
            alert('Please enter a valid amount');
            return;
        }
        
        try {
            const response = await fetch('/Home/UpdatePlayerBalance', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ playerId, amount: parsedAmount })
            });
            
            if (response.ok) {
                alert('Balance updated successfully');
                await loadPlayersTable();
            } else {
                alert('Failed to update balance');
            }
        } catch (error) {
            console.error('Error updating balance:', error);
            alert('Error updating balance');
        }
    }

    /**
     * Edit player details
     */
    function editPlayerDetail(playerId) {
        const player = allPlayers.find(p => p.id === playerId);
        if (!player) return;
        
        const newUsername = prompt('Edit username:', player.username);
        if (newUsername && newUsername.trim()) {
            // You can implement a backend endpoint for this if needed
            alert('Edit functionality can be expanded to update more fields');
        }
    }

    /**
     * Initialize on page load
     */
    document.addEventListener('DOMContentLoaded', function() {
        initDashboard();
    });

    /**
     * Cleanup on page unload
     */
    window.addEventListener('beforeunload', function() {
        if (autoRefreshInterval) clearInterval(autoRefreshInterval);
    });
</script>
</body>
</html>
