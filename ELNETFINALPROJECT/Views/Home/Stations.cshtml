@{
    ViewData["Title"] = "Stations - GameTime";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
        :root { --bg: #0b1410; --bg2: #111a16; --bg3: #172018; --bg4: #1e2b20; --card: #141f16; --border: rgba(0,255,100,0.08); --border2: rgba(0,255,100,0.15); --green: #00e872; --green-dim: rgba(0,232,114,0.12); --text:#e8f5ec; --text2:#8aaa90; --text3:#506055; --sidebar-w:220px; }
        body { font-family: 'DM Sans', sans-serif; background: var(--bg); color: var(--text); min-height: 100vh; display:flex; flex-direction:column; }
        /* TOP NAV */
        .topnav {
            height: 52px;
            background: var(--bg2);
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            padding: 0 20px;
            gap: 16px;
            position: sticky;
            top: 0;
            z-index: 100;
        }
        .topnav-brand {
            display: flex;
            align-items: center;
            gap: 8px;
            font-weight: 700;
            font-size: 15px;
            letter-spacing: 0.5px;
            text-decoration: none;
            color: var(--text);
        }
        .brand-icon {
            width: 28px; height: 28px;
            background: var(--green);
            border-radius: 7px;
            display: flex; align-items: center; justify-content: center;
        }
        .brand-icon svg { color: #0b1410; }
        .brand-label span { color: var(--green); }
        .admin-pill {
            font-size: 10px; font-weight: 600;
            background: var(--green-dim);
            color: var(--green);
            border: 1px solid var(--border2);
            border-radius: 4px;
            padding: 2px 7px;
            letter-spacing: 1px;
            text-transform: uppercase;
        }
        .topnav-search {
            flex: 1;
            max-width: 320px;
            margin-left: 24px;
            position: relative;
        }
        .topnav-search input {
            width: 100%;
            background: var(--bg3);
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: 7px 12px 7px 34px;
            font-size: 13px;
            color: var(--text);
            font-family: 'DM Sans', sans-serif;
            outline: none;
        }
        .topnav-search input::placeholder { color: var(--text3); }
        .topnav-search input:focus { border-color: var(--border2); }
        .search-icon {
            position: absolute; left: 10px; top: 50%;
            transform: translateY(-50%);
            color: var(--text3); font-size: 14px;
        }
        .topnav-right {
            margin-left: auto;
            display: flex;
            align-items: center;
            gap: 14px;
        }
        .status-pill {
            display: flex; align-items: center; gap: 6px;
            background: var(--green-dim);
            border: 1px solid var(--border2);
            border-radius: 20px;
            padding: 5px 12px;
            font-size: 12px;
            font-weight: 500;
            color: var(--green);
        }
        .status-dot {
            width: 7px; height: 7px;
            background: var(--green);
            border-radius: 50%;
            animation: pulse 2s infinite;
        }
        @@keyframes pulse { 0%,100%{opacity:1;} 50%{opacity:0.5;} }
        .topnav-icon-btn {
            width: 34px; height: 34px;
            background: var(--bg3);
            border: 1px solid var(--border);
            border-radius: 8px;
            display: flex; align-items: center; justify-content: center;
            cursor: pointer; color: var(--text2);
            font-size: 15px;
            position: relative;
            transition: border-color 0.2s;
        }
        .topnav-icon-btn:hover { border-color: var(--border2); color: var(--text); }
        .notif-badge {
            position: absolute; top: -4px; right: -4px;
            width: 16px; height: 16px;
            background: var(--red);
            border-radius: 50%;
            font-size: 9px;
            display: flex; align-items: center; justify-content: center;
            font-weight: 700;
            color: #fff;
        }
        .user-chip {
            display: flex; align-items: center; gap: 8px;
            background: var(--bg3);
            border: 1px solid var(--border);
            border-radius: 10px;
            padding: 5px 10px 5px 6px;
            cursor: pointer;
        }
        .user-avatar {
            width: 26px; height: 26px;
            background: linear-gradient(135deg, var(--green), var(--green2));
            border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            font-size: 11px; font-weight: 700; color: #0b1410;
        }
        .user-info { line-height: 1.2; }
        .user-name { font-size: 12px; font-weight: 600; }
        .user-role { font-size: 10px; color: var(--text3); }

        /* LAYOUT */
        .app-body {
            display: flex;
            flex: 1;
            overflow: hidden;
        }

        /* SIDEBAR */
        .sidebar {
            width: var(--sidebar-w);
            background: var(--bg2);
            border-right: 1px solid var(--border);
            padding: 20px 12px;
            display: flex;
            flex-direction: column;
            gap: 8px;
            position: sticky;
            top: 52px;
            height: calc(100vh - 52px);
            overflow-y: auto;
        }
        .sidebar-section-label {
            font-size: 10px;
            font-weight: 600;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            color: var(--text3);
            padding: 4px 8px;
            margin-top: 8px;
        }
        .sidebar-item {
            display: flex; align-items: center; gap: 10px;
            padding: 8px 10px;
            border-radius: 8px;
            cursor: pointer;
            font-size: 13px;
            font-weight: 500;
            color: var(--text2);
            text-decoration: none;
            transition: all 0.15s;
        }
        .sidebar-item:hover { background: var(--bg3); color: var(--text); }
        .sidebar-item.active {
            background: var(--green-dim);
            color: var(--green);
            border: 1px solid var(--border2);
        }
        .sidebar-item i { font-size: 15px; width: 18px; text-align: center; }
        .sidebar-badge {
            margin-left: auto;
            background: var(--bg4);
            color: var(--text2);
            font-size: 11px;
            padding: 1px 7px;
            border-radius: 10px;
            font-weight: 500;
        }
        .sidebar-item.active .sidebar-badge {
            background: rgba(0,232,114,0.2);
            color: var(--green);
        }

        .sidebar-bottom {
            margin-top: auto;
            border-top: 1px solid var(--border);
            padding-top: 14px;
            display: flex; flex-direction: column; gap: 4px;
        }
        .station-occ {
            padding: 10px;
            background: var(--bg3);
            border-radius: 8px;
            border: 1px solid var(--border);
            margin-bottom: 8px;
        }
        .occ-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 6px; }
        .occ-label { font-size: 11px; color: var(--text3); }
        .occ-count { font-size: 12px; font-weight: 600; }
        .occ-bar { height: 4px; background: var(--bg4); border-radius: 2px; overflow: hidden; }
        .occ-fill { height: 100%; background: var(--green); border-radius: 2px; width: 70%; }
        .occ-sub { font-size: 10px; color: var(--text3); margin-top: 5px; }
        .server-load {
            display: flex; align-items: center; justify-content: space-between;
            padding: 8px 10px;
            background: var(--bg3);
            border-radius: 8px;
            border: 1px solid var(--border);
        }
        .server-left { display: flex; align-items: center; gap: 8px; }
        .server-icon { font-size: 14px; color: var(--green); }
        .server-info { line-height: 1.3; }
        .server-title { font-size: 11px; color: var(--text2); font-weight: 500; }
        .server-sub { font-size: 10px; color: var(--text3); }
        .server-dot { width: 8px; height: 8px; background: var(--green); border-radius: 50%; }
        .app-body{display:flex;flex:1;overflow:hidden}
        .main{flex:1;overflow-y:auto;padding:24px;display:flex;gap:20px}
        .main-left{flex:1;min-width:0;display:flex;flex-direction:column;gap:20px}
        .panel{background:var(--card);border:1px solid var(--border);border-radius:12px;padding:18px}
        .muted{color:var(--text3)}

    </style>
</head>
<body>

<nav class="topnav">
    <div class="topnav-search">
        <i class="bi bi-search search-icon"></i>
        <input type="text" placeholder="Search players, stations..." />
    </div>
    <div class="topnav-right">
        <div class="status-pill"><div class="status-dot"></div></div>
        <div class="topnav-icon-btn"><i class="bi bi-gear"></i></div>
        <div class="topnav-icon-btn"><i class="bi bi-bell"></i><span class="notif-badge"></span></div>
        <div class="user-chip"><div class="user-avatar"></div><div class="user-info"><div class="user-name"></div><div class="user-role"></div></div><i class="bi bi-chevron-down" style="font-size:10px;color:var(--text3);margin-left:2px;"></i></div>
    </div>
</nav>

<div class="app-body">
    <!-- SIDEBAR -->
    <aside class="sidebar">
        <div style="display:flex;align-items:center;gap:8px;padding:8px 10px;margin-bottom:8px;">
        <div style="width:34px;height:34px;border-radius:8px;background:var(--green);display:flex;align-items:center;justify-content:center;">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                <path d="M5 10h4M7 8v4" stroke="#07120d" stroke-width="1.6" stroke-linecap="round"/>
                <circle cx="14" cy="9" r="1" fill="#07120d"/>
                <circle cx="16" cy="11" r="1" fill="#07120d"/>
            </svg>
        </div>
        <div style="font-weight:700;color:var(--text);font-size:14px;">
            <span style="color:var(--green)">Game</span>Time
        </div>
        <div style="margin-left:auto;">
            <span class="admin-pill">Admin</span>
        </div>
    </div>
        <div class="sidebar-section-label">Navigation</div>
        <a class="sidebar-item" href="@Url.Action("Dashboard","Home")"><i class="bi bi-speedometer2"></i> Dashboard</a>
        <a class="sidebar-item" href="@Url.Action("Players","Home")"><i class="bi bi-people-fill"></i> Players <span class="sidebar-badge"></span></a>
        <a class="sidebar-item" href="@Url.Action("Stations","Home")"><i class="bi bi-display"></i> Stations <span class="sidebar-badge"></span></a>
        <a class="sidebar-item" href="@Url.Action("Games","Home")"><i class="bi bi-controller"></i> Games <span class="sidebar-badge"></span></a>

        <div class="sidebar-section-label">System</div>
        <a class="sidebar-item" href="#"><i class="bi bi-gear"></i> Settings</a>
        <a class="sidebar-item" href="#"><i class="bi bi-headset"></i> Support <span class="sidebar-badge" style="background:rgba(255,77,77,0.15);color:var(--red);"></span></a>

        <div class="sidebar-bottom">
            <div class="station-occ">
                <div class="occ-header">
                    <span class="occ-label">Station Occupancy</span>
                    <span class="occ-count"></span>
                </div>
                <div class="occ-bar"><div class="occ-fill" style="width:0%"></div></div>
                <div class="occ-sub"></div>
            </div>
            <div class="server-load">
                <div class="server-left">
                    <i class="bi bi-hdd-network server-icon"></i>
                    <div class="server-info">
                        <div class="server-title"></div>
                        <div class="server-sub"></div>
                    </div>
                </div>
                <div class="server-dot"></div>
            </div>
        </div>
    </aside>

    <main class="main">
        <div class="main-left">
            <div class="panel">
                <div style="font-size:16px;font-weight:700;margin-bottom:8px;">STATIONS</div>
                <div class="muted">Stations view placeholder. Implement UI here.</div>
            </div>
        </div>
        <aside class="main-right">
            <div class="panel">
                <div style="font-weight:700;margin-bottom:8px;color:var(--text2);">INFO</div>
                <div class="muted">Station overview and statuses.</div>
            </div>
        </aside>
    </main>
</div>

</body>
</html>