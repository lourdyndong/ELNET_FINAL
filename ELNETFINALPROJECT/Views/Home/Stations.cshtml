@{
    ViewData["Title"] = "Stations - GameTime";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/stations.css" />
</head>
<body>

<!-- TOP NAV -->
<nav class="topnav">
    <a class="topnav-brand" href="#">
        <div class="brand-icon">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                <path d="M3 8h4M5 6v4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                <circle cx="10.5" cy="7" r="0.8" fill="currentColor"/>
                <circle cx="12.5" cy="9" r="0.8" fill="currentColor"/>
                <path d="M1 6C1 4.9 1.9 4 3 4h10C14.1 4 15 4.9 15 6v3c0 1.7-1.3 3-3 3H4C2.3 12 1 10.7 1 9V6z" stroke="currentColor" stroke-width="1.4" fill="none"/>
            </svg>
        </div>
        <span class="brand-label"><span>Game</span>Time</span>
        <span class="admin-pill">Admin</span>
    </a>
    <div class="topnav-search">
        <i class="bi bi-search search-icon"></i>
        <input type="text" placeholder="Search players, stations..." />
    </div>
    <div class="topnav-right">
        <div class="status-pill"><div class="status-dot"></div></div>
        <div class="topnav-icon-btn"><i class="bi bi-bell"></i></div>
        <div class="user-chip">
            <div class="user-avatar">A</div>
            <div style="line-height:1.2;">
                <div class="user-name">Admin</div>
                <div class="user-role">Manager</div>
            </div>
        </div>
    </div>
</nav>

<div class="app-body">
    <!-- SIDEBAR -->
    <partial name="_Sidebar" />

    <!-- MAIN CONTENT -->
    <main class="main">
        <div class="main-left">
            <!-- Page Header -->
            <div>
                <div class="breadcrumb-row">
                    <i class="bi bi-house"></i>
                    <a href="/Home/Dashboard">Dashboard</a>
                    <i class="bi bi-chevron-right"></i>
                    <span style="color:var(--text2);">Stations</span>
                </div>
                <div class="page-header">
                    <div>
                        <h1 class="page-title">Stations</h1>
                        <p class="page-sub">Gaming station overview and real-time status monitoring</p>
                    </div>
                    <div class="header-actions">
                        <button class="btn btn-ghost" onclick="toggleAllStations()"><i class="bi bi-arrow-repeat"></i> Refresh</button>
                        <button class="btn btn-primary" onclick="addStation()"><i class="bi bi-plus-lg"></i> Add Station</button>
                    </div>
                </div>
            </div>

            <!-- Stations Panel -->
            <div class="stations-panel">
                <div class="section-header">
                    <div class="section-title">
                        <i class="bi bi-display-fill"></i>
                        PC Management
                        <span class="section-sub">Manage all 40 gaming PCs and player sessions</span>
                    </div>
                    <div class="legend">
                        <div class="legend-item"><div class="legend-dot dot-green"></div> Active</div>
                        <div class="legend-item"><div class="legend-dot dot-red"></div> Offline</div>
                        <div class="legend-item"><div class="legend-dot" style="background:var(--text3);"></div> Available</div>
                    </div>
                </div>
                <div class="stations-grid" id="stationsGrid">
                    <!-- PC cards will be generated here -->
                </div>
            </div>
        </div>

        <!-- RIGHT PANEL - PC MANAGEMENT -->
        <aside class="main-right">
            <div id="pcManagementPanel" style="display:none;">
                <div class="pc-management-panel">
                    <div class="pc-management-header">
                        <div class="pc-management-title">
                            <i class="bi bi-display-fill"></i>
                            <span id="pcTitle">PC Management</span>
                        </div>
                        <button onclick="closePCManagement()" style="background:none; border:none; color:var(--text2); font-size:18px; cursor:pointer;"><i class="bi bi-x-lg"></i></button>
                    </div>
                    <div class="pc-management-body">
                        <div class="pc-info-row">
                            <span class="pc-info-label">Status</span>
                            <span class="pc-info-value" id="pcStatus">—</span>
                        </div>
                        <div class="pc-info-row">
                            <span class="pc-info-label">Current User</span>
                            <span class="pc-info-value" id="pcCurrentUser">—</span>
                        </div>
                        <div class="pc-info-row">
                            <span class="pc-info-label">Time Used / Paid</span>
                            <span class="pc-info-value" id="pcTimeUsed">—</span>
                        </div>
                        <div class="pc-management-actions">
                            <button class="pc-action-btn guest-login" onclick="openGuestLoginModal()">
                                <i class="bi bi-person-plus"></i> Guest Login
                            </button>
                            <button class="pc-action-btn power" id="pcPowerBtn" onclick="togglePCPower()">
                                <i class="bi bi-power"></i> Power
                            </button>
                            <button class="pc-action-btn warn" onclick="markPCUnavailable()">
                                <i class="bi bi-exclamation-triangle"></i> Mark Unavailable
                            </button>
                            <button class="pc-action-btn" style="background:#2a1010;border-color:#5a1b1b;color:#ffb5b5;" onclick="removeStation()">
                                <i class="bi bi-trash"></i> Remove Station
                            </button>
                            <div style="display:flex;gap:8px;align-items:center;">
                                <input id="assignPlayerName" placeholder="Assign player name" style="padding:6px;border-radius:6px;border:1px solid var(--border);background:var(--bg3);color:var(--text);" />
                                <button class="pc-action-btn primary" onclick="(function(){ assignPlayerToPC(document.getElementById('assignPlayerName').value, 60); })()">Assign</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div id="emptyPanel" style="display:block;">
                <div class="info-panel">
                    <div class="info-header">
                        <i class="bi bi-info-circle-fill"></i>
                        <div>
                            <div class="info-header-title">Info</div>
                            <div class="info-header-sub">PC overview and statuses</div>
                        </div>
                    </div>
                    <div class="info-body">
                        <div class="info-stat">
                            <span class="info-stat-label">Total PCs</span>
                            <span class="info-stat-value" id="infoTotal">40</span>
                        </div>
                        <div class="info-stat">
                            <span class="info-stat-label">Active</span>
                            <span class="info-stat-value green" id="infoActive">0</span>
                        </div>
                        <div class="info-stat">
                            <span class="info-stat-label">Offline</span>
                            <span class="info-stat-value red" id="infoOffline">0</span>
                        </div>
                        <div class="info-stat">
                            <span class="info-stat-label">Available</span>
                            <span class="info-stat-value" id="infoAvailable">0</span>
                        </div>
                        <div style="font-size:11px; color:var(--text3); margin-top:4px;">
                            Click any PC card to manage or click "Guest Login" to add a guest session.
                        </div>
                    </div>
                </div>
            </div>
        </aside>
    </main>
</div>

<!-- Guest Login Modal -->
<div id="guestLoginModal" class="modal-overlay">
    <div class="modal-content">
        <div class="modal-header">
            <div class="modal-title">
                <i class="bi bi-person-plus"></i>
                <span id="modalPCTitle">PC — Guest Login</span>
            </div>
            <button onclick="closeGuestLoginModal()" class="modal-close"><i class="bi bi-x-lg"></i></button>
        </div>
        <form class="modal-form" onsubmit="processGuestLogin(event)">
            <div class="form-group">
                <label class="form-label">Guest Name</label>
                <input id="guestName" type="text" class="form-input" placeholder="Enter guest name" required />
            </div>
            <div class="form-group">
                <label class="form-label">Payment Amount (Pesos)</label>
                <input id="paymentAmount" type="number" class="form-input" placeholder="e.g., 20, 40, 60" min="20" step="20" required />
                <div class="time-calc-info">
                    <strong>Rate:</strong> 20 pesos = 1 hour | <strong>Time:</strong> <span id="calcTime">—</span>
                </div>
            </div>
            <div class="payment-calc">
                <div class="payment-item">
                    <span class="payment-item-label">Total Payment</span>
                    <span class="payment-item-value" id="paymentTotal">₱0</span>
                </div>
                <div class="payment-item">
                    <span class="payment-item-label">Session Time</span>
                    <span class="payment-item-value" id="sessionTime">0h 0m</span>
                </div>
            </div>
            <div id="guestError" class="form-error"></div>
            <button type="submit" class="form-button"><i class="bi bi-check-circle"></i> Confirm & Start Session</button>
        </form>
    </div>
</div>

    <script src="~/js/stations.js"></script>
</body>
</html>
