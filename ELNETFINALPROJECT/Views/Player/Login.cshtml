@{
    ViewData["Title"] = "Player Login - GameTime";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;500;600;700&family=DM+Sans:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

        :root {
            --green: #00ff88;
            --green2: #00cc6a;
            --green-dim: rgba(0,255,136,0.1);
            --green-glow: rgba(0,255,136,0.15);
            --bg-dark: #060e0a;
            --bg-panel: #0a1410;
            --bg-input: #0d1a14;
            --border: rgba(0,255,136,0.15);
            --border2: rgba(0,255,136,0.35);
            --text: #e8f5ec;
            --text2: #7a9a85;
            --text3: #3a5a45;
            --red: #ff3355;
        }

        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--bg-dark);
            color: var(--text);
            min-height: 100vh;
            display: flex;
            overflow: hidden;
        }

        /* LEFT PANEL - Gaming image side */
        .left-panel {
            flex: 1;
            position: relative;
            overflow: hidden;
            min-height: 100vh;
        }

        .left-bg {
            position: absolute;
            inset: 0;
            background:
                linear-gradient(135deg, rgba(0,20,10,0.3) 0%, rgba(0,40,20,0.5) 100%),
                radial-gradient(ellipse at 30% 60%, rgba(0,255,100,0.08) 0%, transparent 60%);
            background-color: #0a1a10;
        }

        /* Simulated gaming arena background */
        .arena-bg {
            position: absolute;
            inset: 0;
            background:
                radial-gradient(ellipse at 50% 40%, rgba(0,60,30,0.6) 0%, transparent 70%),
                linear-gradient(180deg, #061008 0%, #0a1f10 40%, #061008 100%);
        }

        /* Grid floor effect */
        .grid-floor {
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            height: 60%;
            background:
                linear-gradient(rgba(0,255,100,0.03) 1px, transparent 1px),
                linear-gradient(90deg, rgba(0,255,100,0.03) 1px, transparent 1px);
            background-size: 40px 40px;
            transform: perspective(500px) rotateX(40deg);
            transform-origin: bottom;
            opacity: 0.6;
        }

        /* Glow screens effect */
        .screens-glow {
            position: absolute;
            top: 15%;
            left: 10%;
            right: 10%;
            height: 45%;
            background:
                radial-gradient(ellipse at 20% 50%, rgba(0,255,100,0.12) 0%, transparent 40%),
                radial-gradient(ellipse at 80% 50%, rgba(0,200,80,0.1) 0%, transparent 40%),
                radial-gradient(ellipse at 50% 30%, rgba(0,255,150,0.08) 0%, transparent 50%);
        }

        /* Screen boxes */
        .screen-boxes {
            position: absolute;
            top: 12%;
            left: 8%;
            right: 8%;
            display: flex;
            gap: 8px;
            align-items: flex-end;
        }
        .screen-box {
            background: rgba(0,30,15,0.8);
            border: 1px solid rgba(0,255,100,0.2);
            border-radius: 4px;
            flex: 1;
            position: relative;
            overflow: hidden;
        }
        .screen-box::before {
            content: '';
            display: block;
            padding-top: 60%;
        }
        .screen-box-inner {
            position: absolute;
            inset: 4px;
            background: linear-gradient(135deg, rgba(0,40,20,0.9), rgba(0,20,10,0.9));
            border-radius: 2px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 10px;
            color: rgba(0,255,100,0.4);
            font-family: 'JetBrains Mono', monospace;
        }
        .screen-box:nth-child(2) { flex: 1.6; }
        .screen-box:nth-child(2) .screen-box-inner { font-size: 14px; color: rgba(0,255,100,0.6); }
        .screen-box-glow {
            position: absolute;
            bottom: -10px;
            left: 50%;
            transform: translateX(-50%);
            width: 80%;
            height: 20px;
            background: radial-gradient(ellipse, rgba(0,255,100,0.3), transparent);
            filter: blur(8px);
        }

        /* Desk / station row */
        .stations-row {
            position: absolute;
            bottom: 25%;
            left: 5%;
            right: 5%;
            height: 80px;
            display: flex;
            gap: 6px;
            align-items: flex-end;
        }
        .station-desk {
            flex: 1;
            height: 100%;
            background: rgba(0,20,10,0.7);
            border: 1px solid rgba(0,255,100,0.1);
            border-radius: 4px 4px 0 0;
            position: relative;
            overflow: hidden;
        }
        .station-desk::after {
            content: '';
            position: absolute;
            top: 8px;
            left: 50%;
            transform: translateX(-50%);
            width: 60%;
            height: 40%;
            background: rgba(0,40,20,0.8);
            border: 1px solid rgba(0,255,100,0.15);
            border-radius: 2px;
        }
        .station-desk.active::before {
            content: '';
            position: absolute;
            top: 4px;
            right: 6px;
            width: 4px;
            height: 4px;
            background: var(--green);
            border-radius: 50%;
            box-shadow: 0 0 6px var(--green);
        }

        .left-overlay {
            position: absolute;
            inset: 0;
            background: linear-gradient(to right, transparent 60%, var(--bg-panel) 100%);
        }

        /* Brand badge */
        .left-brand {
            position: absolute;
            top: 28px;
            left: 28px;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .brand-logo {
            width: 36px;
            height: 36px;
            background: var(--green);
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .brand-logo svg { color: #060e0a; }
        .brand-text-wrap { line-height: 1.1; }
        .brand-name { font-family: 'Rajdhani', sans-serif; font-size: 16px; font-weight: 700; color: var(--green); letter-spacing: 1px; }
        .brand-sub { font-size: 9px; color: var(--text2); letter-spacing: 2px; text-transform: uppercase; }

        /* Hero text */
        .hero-text {
            position: absolute;
            bottom: 18%;
            left: 28px;
            right: 28px;
        }
        .hero-title {
            font-family: 'Rajdhani', sans-serif;
            font-size: 42px;
            font-weight: 700;
            line-height: 1.0;
            letter-spacing: -0.5px;
            color: #fff;
            text-shadow: 0 0 40px rgba(0,255,100,0.2);
            margin-bottom: 12px;
        }
        .hero-subtitle {
            font-size: 12px;
            color: var(--text2);
            line-height: 1.6;
            max-width: 340px;
        }

        /* Stats row */
        .hero-stats {
            display: flex;
            gap: 20px;
            margin-top: 16px;
        }
        .hero-stat {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 11px;
            color: var(--green);
            font-weight: 500;
        }
        .hero-stat i { font-size: 12px; }

        /* Version */
        .left-version {
            position: absolute;
            bottom: 14px;
            left: 28px;
            font-size: 9px;
            color: var(--text3);
            font-family: 'JetBrains Mono', monospace;
            letter-spacing: 1px;
        }

        /* RIGHT PANEL - Login form */
        .right-panel {
            width: 420px;
            min-height: 100vh;
            background: var(--bg-panel);
            border-left: 1px solid var(--border);
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            padding: 48px 40px 24px;
            position: relative;
            flex-shrink: 0;
        }

        /* Subtle top glow */
        .right-panel::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 2px;
            background: linear-gradient(90deg, transparent, var(--green), transparent);
            opacity: 0.5;
        }

        .form-top-label {
            font-size: 10px;
            font-weight: 700;
            letter-spacing: 2px;
            text-transform: uppercase;
            color: var(--green);
            margin-bottom: 6px;
        }

        .form-title {
            font-family: 'Rajdhani', sans-serif;
            font-size: 38px;
            font-weight: 700;
            letter-spacing: -0.5px;
            color: #fff;
            margin-bottom: 36px;
            line-height: 1.0;
        }

        /* Form fields */
        .field-group { margin-bottom: 20px; }
        .field-label {
            display: flex;
            align-items: center;
            justify-content: space-between;
            font-size: 9px;
            font-weight: 700;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            color: var(--text2);
            margin-bottom: 8px;
        }
        .field-required { color: var(--green); font-size: 8px; letter-spacing: 1px; }
        .field-link { color: var(--green); font-size: 9px; text-decoration: none; letter-spacing: 1px; transition: opacity 0.2s; }
        .field-link:hover { opacity: 0.7; }

        .field-input {
            width: 100%;
            background: var(--bg-input);
            border: 1px solid var(--border);
            border-radius: 4px;
            padding: 14px 16px;
            font-size: 13px;
            color: var(--text);
            font-family: 'DM Sans', sans-serif;
            outline: none;
            transition: border-color 0.2s, box-shadow 0.2s;
        }
        .field-input::placeholder { color: var(--text3); }
        .field-input:focus {
            border-color: var(--green);
            box-shadow: 0 0 0 3px rgba(0,255,136,0.08);
        }

        .password-wrap { position: relative; }
        .password-wrap .field-input { padding-right: 44px; }
        .password-toggle {
            position: absolute;
            right: 14px;
            top: 50%;
            transform: translateY(-50%);
            background: none;
            border: none;
            color: var(--text3);
            cursor: pointer;
            font-size: 15px;
            padding: 0;
            transition: color 0.2s;
        }
        .password-toggle:hover { color: var(--green); }

        /* Remember me */
        .remember-row {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 24px;
        }
        .remember-checkbox {
            width: 14px;
            height: 14px;
            accent-color: var(--green);
            cursor: pointer;
        }
        .remember-label {
            font-size: 11px;
            color: var(--text2);
            cursor: pointer;
        }

        /* Submit button */
        .submit-btn {
            width: 100%;
            padding: 15px;
            background: var(--green);
            color: #060e0a;
            border: none;
            border-radius: 4px;
            font-family: 'Rajdhani', sans-serif;
            font-size: 15px;
            font-weight: 700;
            letter-spacing: 2px;
            text-transform: uppercase;
            cursor: pointer;
            transition: all 0.2s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            margin-bottom: 20px;
        }
        .submit-btn:hover {
            background: var(--green2);
            box-shadow: 0 4px 20px rgba(0,255,136,0.3);
            transform: translateY(-1px);
        }
        .submit-btn:active { transform: translateY(0); }

        /* Divider */
        .or-divider {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 16px;
        }
        .or-divider-line { flex: 1; height: 1px; background: var(--border); }
        .or-divider-text { font-size: 9px; color: var(--text3); letter-spacing: 1.5px; text-transform: uppercase; }

        /* Social / alternate buttons */
        .alt-btns {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 10px;
            margin-bottom: 24px;
        }
        .alt-btn {
            padding: 11px;
            background: transparent;
            border: 1px solid var(--border);
            border-radius: 4px;
            color: var(--text2);
            font-size: 12px;
            font-family: 'DM Sans', sans-serif;
            cursor: pointer;
            transition: all 0.2s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
        }
        .alt-btn:hover { border-color: var(--border2); color: var(--text); background: var(--green-dim); }

        /* Register link */
        .register-row {
            text-align: center;
            font-size: 12px;
            color: var(--text2);
            margin-bottom: 32px;
        }
        .register-link {
            color: var(--green);
            font-weight: 700;
            text-decoration: none;
            font-size: 11px;
            letter-spacing: 1px;
            text-transform: uppercase;
        }
        .register-link:hover { opacity: 0.7; }

        /* Error message */
        .error-msg {
            background: rgba(255,51,85,0.1);
            border: 1px solid rgba(255,51,85,0.3);
            border-radius: 4px;
            padding: 10px 14px;
            font-size: 12px;
            color: var(--red);
            margin-bottom: 16px;
            display: none;
        }

        /* Bottom status bar */
        .status-bar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding-top: 16px;
            border-top: 1px solid var(--border);
        }
        .status-left { display: flex; flex-direction: column; gap: 3px; }
        .status-label { font-size: 8px; font-weight: 700; letter-spacing: 1.5px; text-transform: uppercase; color: var(--text3); }
        .status-value { display: flex; align-items: center; gap: 5px; font-size: 10px; color: var(--text2); }
        .status-dot { width: 6px; height: 6px; background: var(--green); border-radius: 50%; box-shadow: 0 0 6px var(--green); animation: blink 2s infinite; }
        @@keyframes blink { 0%,100%{opacity:1;} 50%{opacity:0.4;} }
        .status-right { font-size: 9px; color: var(--text3); font-family: 'JetBrains Mono', monospace; text-align: right; line-height: 1.6; }

        /* Scan line animation on inputs */
        .field-input:focus + .scan-line { opacity: 1; }
    </style>
</head>
<body>

    <!-- LEFT PANEL -->
    <div class="left-panel">
        <div class="arena-bg"></div>
        <div class="grid-floor"></div>
        <div class="screens-glow"></div>

        <!-- Simulated screens -->
        <div class="screen-boxes">
            <div class="screen-box">
                <div class="screen-box-inner">PC</div>
                <div class="screen-box-glow"></div>
            </div>
            <div class="screen-box">
                <div class="screen-box-inner"><i class="bi bi-controller"></i></div>
                <div class="screen-box-glow"></div>
            </div>
            <div class="screen-box">
                <div class="screen-box-inner">PC</div>
                <div class="screen-box-glow"></div>
            </div>
        </div>

        <!-- Station desks -->
        <div class="stations-row">
            <div class="station-desk active"></div>
            <div class="station-desk active"></div>
            <div class="station-desk"></div>
            <div class="station-desk active"></div>
            <div class="station-desk"></div>
            <div class="station-desk active"></div>
            <div class="station-desk active"></div>
            <div class="station-desk"></div>
        </div>

        <div class="left-overlay"></div>

        <!-- Brand -->
        <div class="left-brand">
            <div class="brand-logo">
                <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
                    <path d="M4 9h4M6 7v4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                    <circle cx="12" cy="8" r="0.9" fill="currentColor"/>
                    <circle cx="14" cy="10.5" r="0.9" fill="currentColor"/>
                    <path d="M1.5 7C1.5 5.6 2.6 4.5 4 4.5h10C15.4 4.5 16.5 5.6 16.5 7v3c0 2-1.6 3.5-3.5 3.5H5C3.1 13.5 1.5 12 1.5 10V7z" stroke="currentColor" stroke-width="1.4" fill="none"/>
                </svg>
            </div>
            <div class="brand-text-wrap">
                <div class="brand-name">GAMETIME</div>
                <div class="brand-sub">Player Portal Access</div>
            </div>
        </div>

        <!-- Hero text -->
        <div class="hero-text">
            <h1 class="hero-title">ULTIMATE GAMING<br>EXPERIENCE</h1>
            <p class="hero-subtitle">Access real-time telemetry, squad management, and tournament infrastructure for high-performance esports arenas.</p>
            <div class="hero-stats">
                <div class="hero-stat"><i class="bi bi-activity"></i> Live Performance</div>
                <div class="hero-stat"><i class="bi bi-trophy-fill"></i> Active Tournaments</div>
            </div>
        </div>

        <div class="left-version">GT: BUILD/ALPHA/2026 v0.1.2</div>
    </div>

    <!-- RIGHT PANEL -->
    <div class="right-panel">
        <div>
            <div class="form-top-label">Welcome Back, Player</div>
            <h2 class="form-title">PLAYER LOGIN</h2>

            <form method="post" action="/Player/Login" id="loginForm">
                <!-- Error message -->
                <div class="error-msg" id="errorMsg">
                    @if (TempData["Error"] != null)
                    {
                        @TempData["Error"]
                    }
                </div>

                <!-- Username/Email -->
                <div class="field-group">
                    <div class="field-label">
                        <span>Default Input / Identifier</span>
                        <span class="field-required">Required</span>
                    </div>
                    <input type="text" name="username" class="field-input" placeholder="Enter username or email..." required />
                </div>

                <!-- Password -->
                <div class="field-group">
                    <div class="field-label">
                        <span>Active Input / Password</span>
                        <a href="#" class="field-link">Forgot Password?</a>
                    </div>
                    <div class="password-wrap">
                        <input type="password" name="password" id="playerPassword" class="field-input" placeholder="••••••••••" required />
                        <button type="button" class="password-toggle" onclick="togglePassword()">
                            <i class="bi bi-eye-fill" id="eyeIcon"></i>
                        </button>
                    </div>
                </div>

                <!-- Remember me -->
                <div class="remember-row">
                    <input type="checkbox" id="rememberMe" class="remember-checkbox" />
                    <label for="rememberMe" class="remember-label">Remember this device for 30 days</label>
                </div>

                <!-- Submit -->
                <button type="submit" class="submit-btn">
                    Access Portal <i class="bi bi-arrow-right"></i>
                </button>
            </form>

            <!-- OR divider -->
            <div class="or-divider">
                <div class="or-divider-line"></div>
                <span class="or-divider-text">Or Connect Via</span>
                <div class="or-divider-line"></div>
            </div>

            <!-- Alt buttons -->
            <div class="alt-btns">
                <button class="alt-btn"><i class="bi bi-qr-code"></i> QR Code</button>
                <button class="alt-btn"><i class="bi bi-person-badge"></i> Card ID</button>
            </div>

            <!-- Register link -->
            <div class="register-row">
                New to the arena? <a href="#" class="register-link">Register Profile</a>
            </div>
        </div>

        <!-- Bottom status bar -->
        <div class="status-bar">
            <div class="status-left">
                <div class="status-label">System Status</div>
                <div class="status-value">
                    <span class="status-dot"></span>
                    Infrastructure Online
                </div>
            </div>
            <div class="status-right">
                VER: 1.0.2-STABLE<br>
                <span style="color:var(--text3);">GT/2026</span>
            </div>
        </div>
    </div>

    <script>
        // Show error if exists
        const errMsg = document.getElementById('errorMsg');
        if (errMsg && errMsg.textContent.trim()) {
            errMsg.style.display = 'block';
        }

        function togglePassword() {
            const input = document.getElementById('playerPassword');
            const icon = document.getElementById('eyeIcon');
            if (input.type === 'password') {
                input.type = 'text';
                icon.className = 'bi bi-eye-slash-fill';
            } else {
                input.type = 'password';
                icon.className = 'bi bi-eye-fill';
            }
        }

        // Enter key submits
        document.addEventListener('keypress', function(e) {
            if (e.key === 'Enter') document.getElementById('loginForm').submit();
        });
    </script>
</body>
</html>
