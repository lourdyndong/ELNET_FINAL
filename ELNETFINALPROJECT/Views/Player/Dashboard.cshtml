    <script src="/js/payment-control.js"></script>
    <script src="/js/dashboard.js"></script>
    <script>
        // Sidebar avatar fallback initials
        function setDefaultAvatar() {
            $('.sidebar-user-avatar').each(function() {
                var initials = $(this).text().trim();
                if (initials === '') {
                    $(this).text('CG').css('background', '#00ff88');
                }
            });
        }

        setDefaultAvatar();

        // Confirm logout function
        function confirmLogout() {
            if (confirm('Are you sure you want to logout?')) {
                // Redirect to logout endpoint
                window.location.href = '/Player/Logout';
            }
        }

        // Top up modal functions
        function openTopUp() {
            $('#topUpModal').addClass('open');
            $('body').css('overflow', 'hidden');
        }

        function closeTopUp() {
            $('#topUpModal').removeClass('open');
            $('body').css('overflow', '');
        }

        function selectAmount(amount, el) {
            topUpAmount = amount;
            $('.amount-preset').removeClass('selected');
            if (el) $(el).addClass('selected');
            $('#customAmount').val('');
        }

        function onCustomAmount(value) {
            topUpAmount = parseFloat(value) || 0;
            $('.amount-preset').removeClass('selected');
        }

        function clearPresets() {
            $('.amount-preset').removeClass('selected');
        }

        function showPayMethod(method) {
            $('#cardFields').hide();
            $('#gcashFields').hide();
            $('#walletFields').hide();
            $('#' + method + 'Fields').show();
        }

        function formatCardNumber(input) {
            let val = input.value.replace(/\D/g, ''); // Remove non-digits
            let formatted = val.match(/.{1,4}/g);
            input.value = formatted ? formatted.join(' ') : val;
        }

        function formatExpiry(input) {
            let val = input.value.replace(/\D/g, ''); // Remove non-digits
            if (val.length >= 3) {
                input.value = val.substring(0, 2) + '/' + val.substring(2, 4);
            } else {
                input.value = val;
            }
        }

        // Initial setup
        $(document).ready(function() {
            showPayMethod('card');

            // Load real dashboard data from backend
            loadDashboardData();
            getProfileData();

            // Refresh dashboard data every 30 seconds
            setInterval(loadDashboardData, 30000);

            // Close top-up modal on backdrop click
            $('#topUpModal').on('click', function(e) {
                if (e.target === this) {
                    closeTopUp();
                }
            });
        });

        // ── Live session state ────────────────────────────────────────────────
        let _liveSessionData   = null;
        let _liveSessionInterval = null;

        const RATE = 20; // ₱20/hr flat

        /**
         * Format milliseconds as "Xh MMm SSs" for a live, ticking display.
         * Shows seconds so the user can see it counting every second.
         */
        function fmtTime(totalMs) {
            const totalSec = Math.max(0, Math.floor(totalMs / 1000));
            const h = Math.floor(totalSec / 3600);
            const m = Math.floor((totalSec % 3600) / 60);
            const s = totalSec % 60;
            return `${h}h ${String(m).padStart(2, '0')}m ${String(s).padStart(2, '0')}s`;
        }

        /**
         * Parse a UTC datetime string from ASP.NET (which omits the trailing "Z").
         * Without this fix, new Date("2025-05-12T10:00:00") is treated as LOCAL time
         * in most browsers, making the elapsed calculation wrong by the UTC offset
         * (e.g. 8 hours off in the Philippines).
         */
        function parseUtcDate(str) {
            if (!str) return null;
            // Append "Z" if no timezone designator present
            if (!/[Zz]$/.test(str) && !/[+\-]\d{2}:\d{2}$/.test(str)) {
                str = str + 'Z';
            }
            return new Date(str);
        }

        /** Tick — updates elapsed & remaining every second without resetting on polls */
        function _tickLiveSession() {
            if (!_liveSessionData) return;

            const now       = Date.now();
            const elapsedMs = now - _liveSessionData.startMs;
            // Remaining decreases in real-time since the last poll
            const sincePoll   = now - _liveSessionData.pollMs;
            const remainingMs = _liveSessionData.remainingAtPollMs - sincePoll;

            const el = id => document.getElementById(id);

            el('sessionElapsed').textContent   = fmtTime(elapsedMs);
            el('sessionElapsed').className     = 'hero-session-value';
            el('sessionRemaining').textContent = fmtTime(remainingMs);
            el('sessionRemaining').className   = 'hero-session-value';

            // Also update the hero "Remaining Play Time" text to stay in sync
            const totalRemSec = Math.max(0, Math.floor(remainingMs / 1000));
            const rH = Math.floor(totalRemSec / 3600);
            const rM = Math.floor((totalRemSec % 3600) / 60);
            const remTimeEl = document.getElementById('remainingTime');
            if (remTimeEl) remTimeEl.textContent = `${rH}h ${String(rM).padStart(2, '0')}m`;
        }

        function _startLiveTicker() {
            if (_liveSessionInterval) clearInterval(_liveSessionInterval);
            _liveSessionInterval = setInterval(_tickLiveSession, 1000);
        }

        function _stopLiveTicker() {
            if (_liveSessionInterval) { clearInterval(_liveSessionInterval); _liveSessionInterval = null; }
            _liveSessionData = null;
        }

        /** Apply fresh poll data — anchors remaining to current balance without resetting elapsed */
        function _renderLiveSession(data) {
            const stLabel = data.currentStation
                ? 'PC ' + data.currentStation.replace(/\D/g, '').padStart(2, '0')
                : '—';

            const el = id => document.getElementById(id);

            el('sessionStation').textContent = stLabel;
            el('sessionStation').className   = data.currentStation ? 'hero-session-value' : 'hero-session-value';

            el('sessionRate').textContent = data.currentStation ? `₱${RATE} / hr` : '—';
            el('sessionRate').className   = data.currentStation ? 'hero-session-value' : 'hero-session-value';

            if (data.currentStation && data.sessionStartTime) {
                // FIX 1: parse sessionStartTime as UTC (ASP.NET omits the "Z")
                const startDate = parseUtcDate(data.sessionStartTime);
                const startMs   = startDate.getTime();

                // FIX 2: anchor remaining to the CURRENT balance at poll time,
                //         not to elapsed — so re-polling never resets the countdown.
                //         balance (₱) ÷ rate (₱/hr) × 3 600 000 ms/hr = remaining ms
                const remainingAtPollMs = (data.balance / RATE) * 3600000;

                if (_liveSessionData) {
                    // Session already running — only update the balance anchor, keep startMs intact
                    _liveSessionData.pollMs           = Date.now();
                    _liveSessionData.remainingAtPollMs = remainingAtPollMs;
                } else {
                    // First render — initialise everything
                    _liveSessionData = {
                        startMs,
                        pollMs: Date.now(),
                        remainingAtPollMs
                    };
                    _startLiveTicker();
                }

                _tickLiveSession(); // immediate paint
            } else {
                _stopLiveTicker();
                el('sessionElapsed').textContent   = '—';
                el('sessionElapsed').className     = 'hero-session-value';
                el('sessionRemaining').textContent = '—';
                el('sessionRemaining').className   = 'hero-session-value';
            }
        }

        /**
         * Load real dashboard data from backend.
         * Called on page load and every 30 s to re-anchor the balance.
         */
        function loadDashboardData() {
            fetch('/Player/GetDashboardData')
                .then(r => r.json())
                .then(data => {
                    if (!data.success) return;

                    // Balance display
                    $('#balanceDisplay').text('₱' + data.balance.toFixed(2));

                    // Player rank
                    $('#sidebarRank').text(data.playerRank);

                    // Remaining playtime hero card — only set from poll when no active session ticker
                    if (!_liveSessionData) {
                        const remainingTime = `${data.remainingPlaytimeHours}h ${String(data.remainingPlaytimeMinutes).padStart(2, '0')}m`;
                        $('#remainingTime').text(remainingTime);
                    }

                    // Live session card
                    _renderLiveSession(data);
                })
                .catch(err => console.error('Error loading dashboard data:', err));
        }
    </script>
</body>
</html>
