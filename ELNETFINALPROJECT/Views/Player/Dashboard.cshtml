@{
    ViewData["Title"] = "Player Dashboard - GameTime";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;500;600;700&family=DM+Sans:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

        :root {
            --green: #00ff88;
            --green2: #00cc6a;
            --green-dim: rgba(0,255,136,0.08);
            --green-glow: rgba(0,255,136,0.15);
            --bg: #080f0b;
            --bg2: #0c1510;
            --bg3: #101a13;
            --bg4: #141f17;
            --card: #0e1812;
            --border: rgba(0,255,136,0.08);
            --border2: rgba(0,255,136,0.2);
            --text: #d8edd e;
            --text: #d4ecd8;
            --text2: #6a9070;
            --text3: #3a5a40;
            --red: #ff3355;
            --amber: #ffaa00;
            --sidebar-w: 200px;
        }

        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--bg);
            color: var(--text);
            min-height: 100vh;
            display: flex;
            overflow: hidden;
        }

        /* SIDEBAR */
        .sidebar {
            width: var(--sidebar-w);
            background: var(--bg2);
            border-right: 1px solid var(--border);
            display: flex;
            flex-direction: column;
            height: 100vh;
            position: fixed;
            top: 0;
            left: 0;
            z-index: 50;
        }

        .sidebar-brand {
            padding: 16px 14px;
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .brand-icon {
            width: 28px; height: 28px;
            background: var(--green);
            border-radius: 6px;
            display: flex; align-items: center; justify-content: center;
            flex-shrink: 0;
        }
        .brand-icon svg { color: #080f0b; }
        .brand-name {
            font-family: 'Rajdhani', sans-serif;
            font-size: 14px;
            font-weight: 700;
            color: var(--green);
            letter-spacing: 1px;
        }

        /* Station cards in sidebar */
        .sidebar-stations {
            padding: 12px 10px;
            flex: 1;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .sidebar-station-card {
            background: var(--bg3);
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: 10px;
            cursor: pointer;
            transition: border-color 0.2s;
        }
        .sidebar-station-card:hover { border-color: var(--border2); }
        .sidebar-station-card.active { border-color: var(--green); background: var(--green-dim); }

        .ssc-top {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 8px;
        }
        .ssc-label { font-size: 9px; color: var(--text3); font-weight: 600; letter-spacing: 1px; text-transform: uppercase; }
        .ssc-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--text3); }
        .ssc-dot.active { background: var(--green); box-shadow: 0 0 6px var(--green); }

        .ssc-screen {
            width: 100%;
            aspect-ratio: 16/9;
            background: var(--bg4);
            border-radius: 4px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
            color: var(--text3);
            margin-bottom: 8px;
            position: relative;
            overflow: hidden;
        }
        .ssc-screen.active-screen {
            color: var(--green);
            background: rgba(0,255,136,0.05);
            border: 1px solid rgba(0,255,136,0.15);
        }
        .ssc-screen-glow {
            position: absolute;
            inset: 0;
            background: radial-gradient(ellipse at 50% 50%, rgba(0,255,136,0.08), transparent 70%);
        }

        .ssc-action {
            width: 100%;
            padding: 6px;
            border-radius: 4px;
            font-size: 10px;
            font-weight: 700;
            font-family: 'Rajdhani', sans-serif;
            letter-spacing: 1px;
            text-transform: uppercase;
            cursor: pointer;
            border: none;
            transition: all 0.15s;
        }
        .ssc-action.play {
            background: var(--green);
            color: #080f0b;
        }
        .ssc-action.play:hover { background: var(--green2); }
        .ssc-action.assign {
            background: var(--bg4);
            color: var(--text3);
            border: 1px solid var(--border);
        }

        /* Sidebar bottom user */
        .sidebar-user {
            padding: 12px 14px;
            border-top: 1px solid var(--border);
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .sidebar-avatar {
            width: 32px; height: 32px;
            border-radius: 50%;
            background: var(--green-dim);
            border: 1px solid var(--border2);
            display: flex; align-items: center; justify-content: center;
            font-size: 12px; font-weight: 700; color: var(--green);
            flex-shrink: 0;
        }
        .sidebar-user-info { flex: 1; min-width: 0; }
        .sidebar-username { font-size: 12px; font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        .sidebar-logout {
            font-size: 14px;
            color: var(--text3);
            cursor: pointer;
            transition: color 0.2s;
            background: none;
            border: none;
            padding: 0;
        }
        .sidebar-logout:hover { color: var(--red); }

        /* MAIN */
        .main {
            margin-left: var(--sidebar-w);
            flex: 1;
            display: flex;
            flex-direction: column;
            height: 100vh;
            overflow: hidden;
        }

        /* TOP BAR */
        .topbar {
            height: 48px;
            background: var(--bg2);
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 20px;
            flex-shrink: 0;
        }
        .topbar-left { display: flex; align-items: center; gap: 10px; }
        .topbar-section {
            font-size: 9px;
            font-weight: 700;
            letter-spacing: 2px;
            text-transform: uppercase;
            color: var(--text3);
        }
        .topbar-title {
            font-family: 'Rajdhani', sans-serif;
            font-size: 14px;
            font-weight: 700;
            color: var(--text);
            letter-spacing: 0.5px;
        }
        .topbar-title span { color: var(--green); }
        .topbar-right { display: flex; align-items: center; gap: 12px; }
        .topbar-status {
            display: flex; align-items: center; gap: 6px;
            font-size: 10px; color: var(--text2);
        }
        .topbar-status-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--green); box-shadow: 0 0 6px var(--green); animation: pulse 2s infinite; }
        @@keyframes pulse { 0%,100%{opacity:1;} 50%{opacity:0.4;} }
        .topbar-icon { font-size: 16px; color: var(--text3); cursor: pointer; transition: color 0.2s; }
        .topbar-icon:hover { color: var(--text); }

        /* CONTENT */
        .content {
            flex: 1;
            overflow-y: auto;
            padding: 20px;
            display: grid;
            grid-template-columns: 280px 1fr 260px;
            grid-template-rows: auto 1fr;
            gap: 16px;
        }

        /* BALANCE CARD */
        .balance-card {
            grid-column: 1;
            grid-row: 1;
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: 10px;
            padding: 20px;
            position: relative;
            overflow: hidden;
        }
        .balance-card::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0;
            height: 2px;
            background: linear-gradient(90deg, transparent, var(--green), transparent);
            opacity: 0.6;
        }
        .balance-label {
            font-size: 9px; font-weight: 700; letter-spacing: 2px;
            text-transform: uppercase; color: var(--text3);
            margin-bottom: 6px;
        }
        .balance-amount {
            font-family: 'Rajdhani', sans-serif;
            font-size: 44px;
            font-weight: 700;
            color: var(--green);
            line-height: 1;
            letter-spacing: -1px;
            margin-bottom: 4px;
        }
        .balance-time-label {
            font-size: 9px; color: var(--text3); letter-spacing: 1px;
            text-transform: uppercase; margin-bottom: 4px;
        }
        .balance-time {
            font-family: 'JetBrains Mono', monospace;
            font-size: 22px;
            font-weight: 500;
            color: var(--text);
            margin-bottom: 16px;
        }
        .topup-btn {
            width: 100%;
            padding: 10px;
            background: var(--green);
            color: #080f0b;
            border: none;
            border-radius: 5px;
            font-family: 'Rajdhani', sans-serif;
            font-size: 13px;
            font-weight: 700;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            cursor: pointer;
            transition: all 0.2s;
            display: flex; align-items: center; justify-content: center; gap: 6px;
        }
        .topup-btn:hover { background: var(--green2); box-shadow: 0 4px 15px rgba(0,255,136,0.25); }

        /* MAIN STATS AREA */
        .stats-area {
            grid-column: 2;
            grid-row: 1 / 3;
            display: flex;
            flex-direction: column;
            gap: 16px;
        }

        .stats-header {
            font-size: 9px; font-weight: 700; letter-spacing: 2px;
            text-transform: uppercase; color: var(--text3);
            margin-bottom: 4px;
        }

        /* Profile Identity Card */
        .profile-card {
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: 10px;
            padding: 20px;
        }
        .profile-card-title {
            font-size: 10px; font-weight: 700; letter-spacing: 2px;
            text-transform: uppercase; color: var(--text3);
            margin-bottom: 16px;
            display: flex; align-items: center; gap: 6px;
        }
        .profile-card-title i { color: var(--green); }

        .profile-identity {
            display: flex;
            align-items: flex-start;
            gap: 14px;
            margin-bottom: 16px;
        }
        .profile-avatar-wrap { position: relative; }
        .profile-avatar {
            width: 60px; height: 60px;
            border-radius: 50%;
            background: var(--green-dim);
            border: 2px solid var(--border2);
            display: flex; align-items: center; justify-content: center;
            font-size: 22px; font-weight: 700; color: var(--green);
            font-family: 'Rajdhani', sans-serif;
        }
        .profile-avatar-badge {
            position: absolute;
            bottom: 0; right: 0;
            width: 16px; height: 16px;
            background: var(--green);
            border-radius: 50%;
            border: 2px solid var(--card);
            display: flex; align-items: center; justify-content: center;
            font-size: 8px;
            color: #080f0b;
        }
        .profile-info { flex: 1; }
        .profile-username {
            font-family: 'Rajdhani', sans-serif;
            font-size: 20px; font-weight: 700;
            color: var(--text);
            letter-spacing: 0.5px;
            margin-bottom: 2px;
        }
        .profile-email { font-size: 11px; color: var(--text2); margin-bottom: 6px; }
        .profile-id {
            font-family: 'JetBrains Mono', monospace;
            font-size: 10px; color: var(--text3);
        }

        .profile-fields { display: flex; flex-direction: column; gap: 10px; margin-bottom: 14px; }
        .pf-label { font-size: 9px; color: var(--text3); letter-spacing: 1px; text-transform: uppercase; margin-bottom: 4px; }
        .pf-value {
            background: var(--bg3);
            border: 1px solid var(--border);
            border-radius: 5px;
            padding: 9px 12px;
            font-size: 12px;
            color: var(--text2);
        }

        .create-profile-btn {
            width: 100%;
            padding: 10px;
            background: transparent;
            color: var(--green);
            border: 1px solid var(--border2);
            border-radius: 5px;
            font-family: 'Rajdhani', sans-serif;
            font-size: 13px; font-weight: 700;
            letter-spacing: 1.5px; text-transform: uppercase;
            cursor: pointer;
            transition: all 0.2s;
        }
        .create-profile-btn:hover { background: var(--green-dim); }

        /* Activity log card */
        .activity-card {
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: 10px;
            padding: 16px;
            flex: 1;
        }
        .activity-title {
            font-size: 10px; font-weight: 700; letter-spacing: 2px;
            text-transform: uppercase; color: var(--text3);
            margin-bottom: 12px;
            display: flex; align-items: center; justify-content: space-between;
        }
        .activity-item {
            display: flex; align-items: center; gap: 10px;
            padding: 8px 0;
            border-bottom: 1px solid var(--border);
            font-size: 12px;
        }
        .activity-item:last-child { border-bottom: none; }
        .activity-icon {
            width: 28px; height: 28px;
            border-radius: 6px;
            background: var(--green-dim);
            display: flex; align-items: center; justify-content: center;
            font-size: 12px; color: var(--green);
            flex-shrink: 0;
        }
        .activity-info { flex: 1; }
        .activity-name { font-size: 12px; font-weight: 500; }
        .activity-time { font-size: 10px; color: var(--text3); }
        .activity-amount { font-family: 'JetBrains Mono', monospace; font-size: 11px; color: var(--green); }

        /* SECURITY PROTOCOL CARD */
        .security-card {
            grid-column: 3;
            grid-row: 1 / 3;
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: 10px;
            padding: 20px;
            display: flex;
            flex-direction: column;
            gap: 14px;
        }
        .security-title {
            font-size: 10px; font-weight: 700; letter-spacing: 2px;
            text-transform: uppercase; color: var(--text3);
            display: flex; align-items: center; justify-content: space-between;
        }
        .security-badge {
            display: flex; align-items: center; gap: 4px;
            font-size: 9px; color: var(--green);
            background: var(--green-dim);
            border: 1px solid var(--border2);
            border-radius: 10px;
            padding: 2px 8px;
        }
        .security-dot { width: 5px; height: 5px; border-radius: 50%; background: var(--green); }

        .sec-field { }
        .sec-label {
            font-size: 9px; color: var(--text3);
            letter-spacing: 1px; text-transform: uppercase;
            margin-bottom: 5px;
        }
        .sec-input {
            width: 100%;
            background: var(--bg3);
            border: 1px solid var(--border);
            border-radius: 5px;
            padding: 10px 12px;
            font-size: 12px;
            color: var(--text2);
            font-family: 'DM Sans', sans-serif;
            outline: none;
            transition: border-color 0.2s;
        }
        .sec-input:focus { border-color: var(--border2); }
        .sec-input::placeholder { color: var(--text3); }

        .update-btn {
            width: 100%;
            padding: 11px;
            background: var(--green);
            color: #080f0b;
            border: none;
            border-radius: 5px;
            font-family: 'Rajdhani', sans-serif;
            font-size: 12px; font-weight: 700;
            letter-spacing: 1.5px; text-transform: uppercase;
            cursor: pointer;
            transition: all 0.2s;
            margin-top: 4px;
        }
        .update-btn:hover { background: var(--green2); }

        /* Session info */
        .session-card {
            grid-column: 1;
            grid-row: 2;
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: 10px;
            padding: 16px;
        }
        .session-title {
            font-size: 9px; font-weight: 700; letter-spacing: 2px;
            text-transform: uppercase; color: var(--text3);
            margin-bottom: 14px;
            display: flex; align-items: center; gap: 6px;
        }
        .session-title i { color: var(--green); }
        .session-row {
            display: flex; justify-content: space-between; align-items: center;
            padding: 8px 0;
            border-bottom: 1px solid var(--border);
            font-size: 12px;
        }
        .session-row:last-child { border-bottom: none; }
        .session-key { color: var(--text3); font-size: 11px; }
        .session-val { font-family: 'JetBrains Mono', monospace; font-size: 11px; color: var(--text); }
        .session-val.green { color: var(--green); }
        .session-val.amber { color: var(--amber); }

        /* Bottom status bar */
        .status-bar {
            height: 28px;
            background: var(--bg2);
            border-top: 1px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 20px;
            flex-shrink: 0;
        }
        .status-item { display: flex; align-items: center; gap: 5px; font-size: 9px; color: var(--text3); }
        .status-item i { font-size: 10px; }
        .status-green { color: var(--green); }

        /* Cyberpunk network bg effect */
        .network-bg {
            position: fixed;
            top: 0; right: 0;
            width: 400px;
            height: 400px;
            pointer-events: none;
            opacity: 0.04;
            z-index: 0;
        }
    </style>
</head>
<body>

    <!-- Decorative network background -->
    <svg class="network-bg" viewBox="0 0 400 400" fill="none">
        <circle cx="200" cy="200" r="150" stroke="#00ff88" stroke-width="0.5"/>
        <circle cx="200" cy="200" r="100" stroke="#00ff88" stroke-width="0.5"/>
        <circle cx="200" cy="200" r="50" stroke="#00ff88" stroke-width="0.5"/>
        <line x1="50" y1="200" x2="350" y2="200" stroke="#00ff88" stroke-width="0.5"/>
        <line x1="200" y1="50" x2="200" y2="350" stroke="#00ff88" stroke-width="0.5"/>
        <line x1="94" y1="94" x2="306" y2="306" stroke="#00ff88" stroke-width="0.5"/>
        <line x1="306" y1="94" x2="94" y2="306" stroke="#00ff88" stroke-width="0.5"/>
        <circle cx="200" cy="50" r="4" fill="#00ff88"/>
        <circle cx="350" cy="200" r="4" fill="#00ff88"/>
        <circle cx="200" cy="350" r="4" fill="#00ff88"/>
        <circle cx="94" cy="94" r="3" fill="#00ff88"/>
        <circle cx="306" cy="94" r="3" fill="#00ff88"/>
    </svg>

    <!-- SIDEBAR -->
    <aside class="sidebar">
        <div class="sidebar-brand">
            <div class="brand-icon">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                    <path d="M3 8h4M5 6v4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                    <circle cx="10.5" cy="7" r="0.8" fill="currentColor"/>
                    <circle cx="12.5" cy="9" r="0.8" fill="currentColor"/>
                    <path d="M1 6C1 4.9 1.9 4 3 4h10C14.1 4 15 4.9 15 6v3c0 1.7-1.3 3-3 3H4C2.3 12 1 10.7 1 9V6z" stroke="currentColor" stroke-width="1.4" fill="none"/>
                </svg>
            </div>
            <div class="brand-name">GAMETIME</div>
        </div>

        <div class="sidebar-stations">
            <!-- Station card - active -->
            <div class="sidebar-station-card active">
                <div class="ssc-top">
                    <span class="ssc-label">PC 01</span>
                    <span class="ssc-dot active"></span>
                </div>
                <div class="ssc-screen active-screen">
                    <div class="ssc-screen-glow"></div>
                    <i class="bi bi-display-fill"></i>
                </div>
                <button class="ssc-action play">Playing</button>
            </div>

            <!-- Station card - inactive -->
            <div class="sidebar-station-card">
                <div class="ssc-top">
                    <span class="ssc-label">PC 02</span>
                    <span class="ssc-dot"></span>
                </div>
                <div class="ssc-screen">
                    <i class="bi bi-display"></i>
                </div>
                <button class="ssc-action assign">Reserve</button>
            </div>
        </div>

        <div class="sidebar-user">
            <div class="sidebar-avatar" id="sidebarAvatar">—</div>
            <div class="sidebar-user-info">
                <div class="sidebar-username" id="sidebarUsername">Loading...</div>
            </div>
            <button class="sidebar-logout" title="Logout" onclick="confirmLogout()">
                <i class="bi bi-box-arrow-right"></i>
            </button>
        </div>
    </aside>

    <!-- MAIN -->
    <div class="main">
        <!-- TOP BAR -->
        <div class="topbar">
            <div class="topbar-left">
                <span class="topbar-section">Command Center</span>
                <span style="color:var(--text3);">/</span>
                <span class="topbar-title">Welcome back, <span id="topbarName">Agent</span></span>
            </div>
            <div class="topbar-right">
                <div class="topbar-status">
                    <span class="topbar-status-dot"></span>
                    Network Secure
                </div>
                <i class="bi bi-bell topbar-icon"></i>
                <i class="bi bi-gear topbar-icon"></i>
            </div>
        </div>

        <!-- CONTENT -->
        <div class="content">

            <!-- BALANCE CARD -->
            <div class="balance-card">
                <div class="balance-label">Available This Credits</div>
                <div class="balance-amount" id="balanceDisplay">₱0.00</div>
                <div class="balance-time-label">Remaining Time</div>
                <div class="balance-time" id="timeDisplay">0h 00m</div>
                <button class="topup-btn" onclick="openTopUp()">
                    <i class="bi bi-plus-circle-fill"></i> Top Up Balance
                </button>
            </div>

            <!-- STATS / PROFILE AREA -->
            <div class="stats-area">
                <!-- Profile Identity -->
                <div class="profile-card">
                    <div class="profile-card-title">
                        <i class="bi bi-person-badge-fill"></i>
                        Profile Identity
                    </div>
                    <div class="profile-identity">
                        <div class="profile-avatar-wrap">
                            <div class="profile-avatar" id="profileAvatar">—</div>
                            <div class="profile-avatar-badge"><i class="bi bi-check"></i></div>
                        </div>
                        <div class="profile-info">
                            <div class="profile-username" id="profileUsername">—</div>
                            <div class="profile-email" id="profileEmail">—</div>
                            <div class="profile-id" id="profileId">ID: #—</div>
                        </div>
                    </div>
                    <div class="profile-fields">
                        <div>
                            <div class="pf-label">Display Name</div>
                            <div class="pf-value" id="profileDisplayName">—</div>
                        </div>
                    </div>
                    <button class="create-profile-btn">
                        <i class="bi bi-pencil-fill"></i> Edit Profile
                    </button>
                </div>

                <!-- Activity -->
                <div class="activity-card">
                    <div class="activity-title">
                        <span>Recent Activity</span>
                        <span style="font-size:9px; color:var(--text3); font-weight:400;">Session History</span>
                    </div>
                    <div id="activityList">
                        <div class="activity-item">
