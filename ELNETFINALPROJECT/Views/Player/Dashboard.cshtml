    <script>
        let selectedAmount = 100;

        function openTopUp() {
            // Generate transaction ID
            const txId = 'GT-' + Math.floor(10000 + Math.random() * 90000) + '-TX';
            document.getElementById('txId').textContent = 'TRANSACTION ID: ' + txId;
            // Set current balance
            const bal = document.getElementById('balanceDisplay').textContent;
            document.getElementById('summaryBalance').textContent = bal;
            document.getElementById('summaryTopup').textContent = '+₱' + selectedAmount.toFixed(2);
            document.getElementById('topUpModal').style.display = 'flex';
        }

        function closeTopUp() {
            document.getElementById('topUpModal').style.display = 'none';
        }

        function selectAmount(amount) {
            selectedAmount = amount;
            document.getElementById('customAmount').value = '';
            document.getElementById('summaryTopup').textContent = '+₱' + amount.toFixed(2);
            // Update preset styles
            document.querySelectorAll('.amount-preset').forEach(el => {
                el.classList.remove('selected-preset');
                el.style.borderColor = 'rgba(255,255,255,0.15)';
                el.style.background = '#111820';
                el.querySelector('div').style.color = '#fff';
            });
            const amounts = [50, 100, 250];
            const idx = amounts.indexOf(amount);
            if (idx >= 0) {
                document.querySelectorAll('.amount-preset')[idx].classList.add('selected-preset');
            }
        }

        function onCustomAmount(val) {
            const amount = parseFloat(val) || 0;
            selectedAmount = amount;
            document.getElementById('summaryTopup').textContent = '+₱' + amount.toFixed(2);
        }

        function clearPresets() {
            document.querySelectorAll('.amount-preset').forEach(el => {
                el.classList.remove('selected-preset');
                el.style.borderColor = 'rgba(255,255,255,0.15)';
                el.style.background = '#111820';
            });
        }

        function showPayMethod(method) {
            document.getElementById('cardFields').style.display = method === 'card' ? 'block' : 'none';
            document.getElementById('gcashFields').style.display = method === 'gcash' ? 'block' : 'none';
            document.getElementById('walletFields').style.display = method === 'wallet' ? 'block' : 'none';
        }

        function executePayment() {
            if (selectedAmount <= 0) { alert('Please select or enter an amount.'); return; }
            alert('Payment of ₱' + selectedAmount.toFixed(2) + ' submitted!\n(Connect to backend to process real payments)');
            closeTopUp();
        }

        // Close on outside click
        document.getElementById('topUpModal').addEventListener('click', function(e) {
            if (e.target === this) closeTopUp();
        });
    </script>
    <script>
        async function loadPlayerData() {
            try {
                const res = await fetch('/Player/GetProfile');
                if (res.ok) {
                    const data = await res.json();
                    updateUI(data);
                }
            } catch (err) {
                console.error('Failed to load player data:', err);
            }
        }

        function updateUI(data) {
            const name = data.username || '—';
            const initials = name.slice(0, 2).toUpperCase();

            // Topbar
            document.getElementById('topbarName').textContent = name;

            // Sidebar
            document.getElementById('sidebarUsername').textContent = name;
            document.getElementById('sidebarAvatar').textContent = initials;

            // Profile card
            document.getElementById('profileAvatar').textContent = initials;
            document.getElementById('profileUsername').textContent = name;
            document.getElementById('profileEmail').textContent = data.email || '—';
            document.getElementById('profileId').textContent = 'ID: #' + (data.id || '—');
            document.getElementById('profileDisplayName').textContent = name;

            // Balance
            const balance = data.balance || 0;
            document.getElementById('balanceDisplay').textContent = '₱' + balance.toFixed(2);

            // Time remaining (₱20 = 1hr)
            const hours = Math.floor(balance / 20);
            const mins = Math.floor((balance % 20) / 20 * 60);
            document.getElementById('timeDisplay').textContent = hours + 'h ' + String(mins).padStart(2, '0') + 'm';
            document.getElementById('secTimeLeft').textContent = hours + 'h ' + String(mins).padStart(2, '0') + 'm';
            document.getElementById('sessionRemaining').textContent = hours + 'h ' + String(mins).padStart(2, '0') + 'm';
        }

        function updateCredentials() {
            const np = document.getElementById('newPassword').value;
            const cp = document.getElementById('confirmPassword').value;
            if (!np || np.length < 6) { alert('Password must be at least 6 characters.'); return; }
            if (np !== cp) { alert('Passwords do not match.'); return; }
            alert('Credentials updated! (Connect to backend to save)');
            document.getElementById('newPassword').value = '';
            document.getElementById('confirmPassword').value = '';
        }

        function confirmLogout() {
            if (confirm('Log out of your session?')) {
                window.location.href = '/Player/Logout';
            }
        }

        // Live clock
        function updateClock() {
            const now = new Date();
            const h = String(now.getHours()).padStart(2, '0');
            const m = String(now.getMinutes()).padStart(2, '0');
            const s = String(now.getSeconds()).padStart(2, '0');
            document.getElementById('currentTime').textContent = h + ':' + m + ':' + s;
        }
        setInterval(updateClock, 1000);
        updateClock();

        // Load data on init
        loadPlayerData();
    </script>
</body>
</html>
