@{
    ViewData["Title"] = "Player Dashboard - GameTime";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;500;600;700&family=DM+Sans:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --green: #00ff88;
            --green2: #00cc6a;
            --green-dim: rgba(0,255,136,0.08);
            --green-glow: rgba(0,255,136,0.15);
            --bg: #111111;
            --bg2: #181818;
            --bg3: #1e1e1e;
            --bg4: #242424;
            --card: #161616;
            --border: rgba(255,255,255,0.07);
            --border2: rgba(0,255,136,0.3);
            --text: #ffffff;
            --text2: #888888;
            --text3: #555555;
            --red: #e53935;
            --amber: #ffaa00;
            --sidebar-w: 240px;
        }

        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--bg);
            color: var(--text);
            min-height: 100vh;
            display: flex;
            overflow: hidden;
        }

        /* ── SIDEBAR ── */
        .sidebar {
            width: var(--sidebar-w);
            background: var(--bg2);
            border-right: 1px solid var(--border);
            display: flex;
            flex-direction: column;
            height: 100vh;
            position: fixed;
            top: 0;
            left: 0;
            z-index: 50;
        }

        .sidebar-brand {
            padding: 18px 20px;
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .brand-icon {
            width: 32px;
            height: 32px;
            background: var(--green);
            border-radius: 7px;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

            .brand-icon svg {
                color: #111;
            }

        .brand-name {
            font-family: 'Rajdhani', sans-serif;
            font-size: 16px;
            font-weight: 700;
            color: var(--text);
            letter-spacing: 1px;
        }

        /* Nav */
        .sidebar-nav {
            padding: 14px 12px 0;
        }

        .nav-item {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px 12px;
            border-radius: 8px;
            font-size: 13px;
            font-weight: 600;
            letter-spacing: 0.5px;
            text-transform: uppercase;
            cursor: pointer;
            transition: background 0.15s;
            color: var(--text2);
            text-decoration: none;
        }

            .nav-item.active {
                background: var(--bg3);
                color: var(--green);
                border: 1px solid rgba(0,255,136,0.12);
            }

            .nav-item i {
                font-size: 16px;
            }

        /* Ad / donation cards */
        .sidebar-ads {
            flex: 1;
            padding: 16px 12px;
            display: flex;
            flex-direction: column;
            gap: 12px;
            overflow-y: auto;
        }

        .ad-card {
            background: var(--bg3);
            border: 1px solid var(--border);
            border-radius: 10px;
            padding: 14px;
            text-align: center;
        }

        .ad-card-img {
            width: 72px;
            height: 72px;
            border-radius: 6px;
            object-fit: cover;
            margin: 0 auto 8px;
            display: block;
            background: var(--bg4);
        }
        /* Placeholder cat illustration using CSS */
        .ad-cat-placeholder {
            width: 72px;
            height: 72px;
            border-radius: 6px;
            background: linear-gradient(135deg, #5bb8d4 0%, #4aa8c4 40%, #3d9db8 100%);
            margin: 0 auto 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 36px;
            overflow: hidden;
            position: relative;
        }

        .ad-title {
            font-size: 12px;
            font-weight: 600;
            color: var(--text);
            margin-bottom: 2px;
        }

        .ad-subtitle {
            font-size: 10px;
            color: var(--text3);
            margin-bottom: 10px;
        }

        .ad-btn {
            width: 100%;
            padding: 8px;
            background: var(--green);
            color: #111;
            border: none;
            border-radius: 5px;
            font-family: 'Rajdhani', sans-serif;
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            cursor: pointer;
            transition: background 0.15s;
        }

            .ad-btn:hover {
                background: var(--green2);
            }

        /* Sidebar user section */
        .sidebar-user {
            padding: 14px 16px;
            border-top: 1px solid var(--border);
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .sidebar-user-avatar {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            object-fit: cover;
            border: 2px solid var(--green);
            flex-shrink: 0;
            background: var(--bg4);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 13px;
            font-weight: 700;
            color: var(--green);
            overflow: hidden;
        }

            .sidebar-user-avatar img {
                width: 100%;
                height: 100%;
                object-fit: cover;
            }

        .sidebar-user-info {
            flex: 1;
            min-width: 0;
        }

        .sidebar-username {
            font-size: 13px;
            font-weight: 600;
            color: var(--text);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .sidebar-rank {
            font-size: 10px;
            font-weight: 700;
            color: var(--green);
            letter-spacing: 0.5px;
            text-transform: uppercase;
        }

        /* Logout button */
        .logout-btn {
            margin: 0 12px 14px;
            width: calc(100% - 24px);
            padding: 10px;
            background: rgba(229,57,53,0.12);
            color: var(--red);
            border: 1px solid rgba(229,57,53,0.25);
            border-radius: 7px;
            font-family: 'Rajdhani', sans-serif;
            font-size: 12px;
            font-weight: 700;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            cursor: pointer;
            transition: all 0.15s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }

            .logout-btn:hover {
                background: rgba(229,57,53,0.2);
                border-color: rgba(229,57,53,0.4);
            }

        /* ── MAIN ── */
        .main {
            margin-left: var(--sidebar-w);
            flex: 1;
            display: flex;
            flex-direction: column;
            height: 100vh;
            overflow: hidden;
        }

        /* TOP BAR */
        .topbar {
            height: 52px;
            background: var(--bg2);
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 24px;
            flex-shrink: 0;
        }

        .topbar-left {
            display: flex;
            align-items: center;
            gap: 8px;
            flex-direction: column;
            align-items: flex-start;
            justify-content: center;
        }

        .topbar-section {
            font-size: 9px;
            font-weight: 700;
            letter-spacing: 2px;
            text-transform: uppercase;
            color: var(--green);
        }

        .topbar-title {
            font-family: 'DM Sans', sans-serif;
            font-size: 15px;
            font-weight: 600;
            color: var(--text);
        }

            .topbar-title span {
                color: var(--green);
            }

        .topbar-right {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .topbar-status {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 11px;
            color: var(--text2);
            font-weight: 500;
        }

        .topbar-status-dot {
            width: 7px;
            height: 7px;
            border-radius: 50%;
            background: var(--green);
            box-shadow: 0 0 6px var(--green);
            animation: pulse 2s infinite;
        }
        @@keyframes pulse {
            0%, 100% {
                opacity: 1;
            }

            50% {
                opacity: 0.4;
            }
        }

        .topbar-divider {
            width: 1px;
            height: 20px;
            background: var(--border);
        }

        .topbar-icon {
            width: 28px;
            height: 28px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
            color: var(--text2);
            cursor: pointer;
            transition: color 0.2s;
            background: none;
            border: none;
        }

            .topbar-icon.info {
                background: var(--green);
                color: #111;
                font-weight: 700;
                font-size: 13px;
            }

        .topbar-terminal {
            font-family: 'JetBrains Mono', monospace;
            font-size: 13px;
            color: var(--text2);
            cursor: pointer;
        }

        /* ── CONTENT ── */
        .content {
            flex: 1;
            overflow-y: auto;
            padding: 20px 24px;
            display: grid;
            grid-template-columns: 1fr 1fr;
            grid-template-rows: auto auto auto;
            gap: 16px;
            align-content: start;
        }

        /* ── BALANCE HERO CARD ── */
        .hero-card {
            grid-column: 1 / 3;
            background: var(--bg2);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 36px 40px;
            position: relative;
            overflow: hidden;
            min-height: 200px;
        }
        /* Network lines background */
        .hero-card-bg {
            position: absolute;
            top: 0;
            right: 0;
            width: 55%;
            height: 100%;
            pointer-events: none;
            opacity: 1;
        }

        .hero-content {
            position: relative;
            z-index: 2;
            max-width: 500px;
        }

        .hero-label {
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 2px;
            text-transform: uppercase;
            color: var(--text2);
            margin-bottom: 8px;
        }

        .hero-balance {
            font-family: 'DM Sans', sans-serif;
            font-size: 64px;
            font-weight: 700;
            color: var(--text);
            line-height: 1;
            letter-spacing: -2px;
            margin-bottom: 20px;
        }

        .hero-time-label {
            font-size: 10px;
            font-weight: 700;
            letter-spacing: 2px;
            text-transform: uppercase;
            color: var(--text2);
            margin-bottom: 4px;
        }

        .hero-time-value {
            font-family: 'DM Sans', sans-serif;
            font-size: 28px;
            font-weight: 600;
            color: var(--text);
            margin-bottom: 24px;
        }

        .topup-btn {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 13px 28px;
            background: var(--green);
            color: #111;
            border: none;
            border-radius: 6px;
            font-family: 'Rajdhani', sans-serif;
            font-size: 13px;
            font-weight: 700;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            cursor: pointer;
            transition: all 0.2s;
        }

            .topup-btn:hover {
                background: var(--green2);
            }

        /* ── PROFILE CARD ── */
        .profile-card {
            background: var(--bg2);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 24px;
            position: relative;
        }

        .card-title {
            font-family: 'DM Sans', sans-serif;
            font-size: 15px;
            font-weight: 700;
            color: var(--text);
            letter-spacing: 0.3px;
            margin-bottom: 20px;
            text-transform: uppercase;
        }

        .profile-identity {
            display: flex;
            align-items: flex-start;
            gap: 16px;
            margin-bottom: 20px;
        }

        .profile-photo-wrap {
            position: relative;
            flex-shrink: 0;
        }

        .profile-photo {
            width: 80px;
            height: 80px;
            border-radius: 8px;
            object-fit: cover;
            background: var(--bg3);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 28px;
            font-weight: 700;
            color: var(--green);
            font-family: 'Rajdhani', sans-serif;
            overflow: hidden;
        }

            .profile-photo img {
                width: 100%;
                height: 100%;
                object-fit: cover;
                border-radius: 8px;
            }

        .profile-edit-btn {
            position: absolute;
            bottom: -4px;
            right: -4px;
            width: 22px;
            height: 22px;
            background: var(--bg3);
            border: 1px solid var(--border);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            font-size: 10px;
            color: var(--text2);
        }

        .profile-info {
            flex: 1;
        }

        .profile-username-text {
            font-family: 'DM Sans', sans-serif;
            font-size: 20px;
            font-weight: 700;
            color: var(--text);
            margin-bottom: 3px;
        }

        .profile-email-text {
            font-size: 12px;
            color: var(--text2);
            margin-bottom: 10px;
        }

        .verified-badge {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            background: var(--green);
            color: #111;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 9px;
            font-weight: 700;
            letter-spacing: 0.5px;
            text-transform: uppercase;
        }

        .field-label {
            font-size: 10px;
            font-weight: 700;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            color: var(--text3);
            margin-bottom: 6px;
        }

        .field-input {
            width: 100%;
            background: var(--bg3);
            border: 1px solid var(--border);
            border-radius: 6px;
            padding: 11px 14px;
            font-size: 14px;
            color: var(--text);
            font-family: 'DM Sans', sans-serif;
            outline: none;
            transition: border-color 0.2s;
            margin-bottom: 16px;
        }

            .field-input:focus {
                border-color: rgba(0,255,136,0.3);
            }

        .update-profile-btn {
            width: 100%;
            padding: 12px;
            background: var(--bg3);
            color: var(--text2);
            border: 1px solid var(--border);
            border-radius: 6px;
            font-family: 'Rajdhani', sans-serif;
            font-size: 12px;
            font-weight: 700;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            cursor: pointer;
            transition: all 0.15s;
        }

            .update-profile-btn:hover {
                border-color: rgba(0,255,136,0.3);
                color: var(--green);
            }

        /* ── SECURITY CARD ── */
        .security-card {
            background: var(--bg2);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 24px;
            display: flex;
            flex-direction: column;
            gap: 0;
        }

        .security-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 20px;
        }

        .secured-badge {
            display: flex;
            align-items: center;
            gap: 5px;
            font-size: 10px;
            font-weight: 700;
            color: var(--green);
            letter-spacing: 0.5px;
        }

        .secured-dot {
            width: 7px;
            height: 7px;
            border-radius: 50%;
            background: var(--green);
            box-shadow: 0 0 6px var(--green);
        }

        .sec-label {
            font-size: 9px;
            font-weight: 700;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            color: var(--text3);
            margin-bottom: 6px;
        }

        .sec-input-wrap {
            position: relative;
            margin-bottom: 14px;
        }

        .sec-input {
            width: 100%;
            background: var(--bg3);
            border: 1px solid var(--border);
            border-radius: 6px;
            padding: 12px 40px 12px 14px;
            font-size: 14px;
            color: var(--text2);
            font-family: 'DM Sans', sans-serif;
            outline: none;
            transition: border-color 0.2s;
        }

            .sec-input:focus {
                border-color: rgba(0,255,136,0.3);
            }

        .sec-input-icon {
            position: absolute;
            right: 12px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--text3);
            font-size: 14px;
            pointer-events: none;
        }

        .update-creds-btn {
            width: 100%;
            padding: 13px;
            background: transparent;
            color: var(--green);
            border: 1px solid rgba(0,255,136,0.35);
            border-radius: 6px;
            font-family: 'Rajdhani', sans-serif;
            font-size: 12px;
            font-weight: 700;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            cursor: pointer;
            transition: all 0.15s;
            margin-top: 6px;
        }

            .update-creds-btn:hover {
                background: var(--green-dim);
                border-color: var(--green);
            }

        /* ── STATUS BAR ── */
        .status-bar {
            grid-column: 1 / 3;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 12px 20px;
            background: var(--bg2);
            border: 1px solid var(--border);
            border-left: 3px solid var(--green);
            border-radius: 10px;
        }

        .status-left {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .status-icon-wrap {
            width: 24px;
            height: 24px;
            border-radius: 50%;
            background: var(--green);
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

            .status-icon-wrap i {
                font-size: 12px;
                color: #111;
            }

        .status-text-main {
            font-size: 13px;
            font-weight: 600;
            color: var(--text);
        }

        .status-text-sub {
            font-size: 11px;
            color: var(--text2);
        }

        .status-right {
            font-size: 11px;
            color: var(--text3);
            font-family: 'JetBrains Mono', monospace;
            letter-spacing: 0.5px;
        }

        /* ── TOP-UP MODAL ── */
        .modal-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,0.88);
            z-index: 1000;
            align-items: center;
            justify-content: center;
            backdrop-filter: blur(4px);
        }

            .modal-overlay.open {
                display: flex;
            }

        .modal-box {
            position: relative;
            width: 820px;
            max-width: 95vw;
            max-height: 95vh;
            overflow-y: auto;
        }

        .modal-outer {
            border: 1px solid rgba(0,180,255,0.35);
            border-radius: 8px;
            padding: 24px;
            background: #0a1014;
            box-shadow: 0 0 40px rgba(0,180,255,0.08);
        }

        .modal-tag {
            font-size: 10px;
            color: rgba(0,180,255,0.5);
            letter-spacing: 2px;
            text-transform: uppercase;
            margin-bottom: 16px;
            font-family: 'JetBrains Mono', monospace;
        }

        .modal-inner {
            border: 1px solid rgba(0,180,255,0.18);
            border-radius: 6px;
            padding: 28px;
            background: #0c1318;
            position: relative;
        }

        .modal-corner {
            position: absolute;
            width: 30px;
            height: 30px;
        }

            .modal-corner.tl {
                top: -1px;
                left: -1px;
                border-top: 2px solid rgba(0,180,255,0.45);
                border-left: 2px solid rgba(0,180,255,0.45);
                border-radius: 4px 0 0 0;
            }

            .modal-corner.tr {
                top: -1px;
                right: -1px;
                border-top: 2px solid rgba(0,180,255,0.45);
                border-right: 2px solid rgba(0,180,255,0.45);
                border-radius: 0 4px 0 0;
            }

            .modal-corner.bl {
                bottom: -1px;
                left: -1px;
                border-bottom: 2px solid rgba(0,180,255,0.45);
                border-left: 2px solid rgba(0,180,255,0.45);
                border-radius: 0 0 0 4px;
            }

            .modal-corner.br {
                bottom: -1px;
                right: -1px;
                border-bottom: 2px solid rgba(0,180,255,0.45);
                border-right: 2px solid rgba(0,180,255,0.45);
                border-radius: 0 0 4px 0;
            }

        .modal-close {
            position: absolute;
            top: 12px;
            right: 12px;
            background: none;
            border: none;
            color: rgba(255,255,255,0.3);
            font-size: 18px;
            cursor: pointer;
            transition: color 0.2s;
        }

            .modal-close:hover {
                color: #fff;
            }

        .modal-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 28px;
            margin-left: 10px;
        }

        .modal-section-label {
            font-size: 9px;
            font-weight: 700;
            letter-spacing: 2px;
            text-transform: uppercase;
            color: var(--green);
            margin-bottom: 10px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .amount-grid {
            display: grid;
            grid-template-columns: 1fr 1fr 1fr;
            gap: 8px;
            margin-bottom: 14px;
        }

        .amount-preset {
            border: 1px solid rgba(255,255,255,0.12);
            border-radius: 4px;
            padding: 10px;
            text-align: center;
            cursor: pointer;
            transition: all 0.15s;
            background: #111820;
        }

            .amount-preset:hover {
                border-color: rgba(0,255,136,0.3);
            }

            .amount-preset.selected {
                border: 2px solid var(--green);
                background: rgba(0,255,136,0.07);
            }

            .amount-preset .ap-val {
                font-family: 'Rajdhani', sans-serif;
                font-size: 18px;
                font-weight: 700;
                color: #fff;
            }

            .amount-preset.selected .ap-val {
                color: var(--green);
            }

            .amount-preset .ap-pts {
                font-size: 9px;
                color: rgba(255,255,255,0.3);
                letter-spacing: 0.5px;
            }

            .amount-preset.selected .ap-pts {
                color: rgba(0,255,136,0.6);
            }

        .modal-input {
            width: 100%;
            background: #111820;
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 4px;
