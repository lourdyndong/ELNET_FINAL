<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Smart Sit-In</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/dashboard.css" asp-append-version="true" />
</head>
<body>
    <!-- Sidebar -->
    <partial name="_StudentSidebar" />

    <!-- Navbar -->
    <partial name="_StudentNavbar" />

    <!-- Main Content -->
    <div class="main-content">
        @RenderBody()
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Sidebar menu active state
        document.querySelectorAll('.sidebar-nav a').forEach(link => {
            if (link.href === window.location.href) {
                link.classList.add('active');
            }
        });

        // Notification dropdown toggle
        const notificationIcon = document.querySelector('.navbar-icon-notification');
        if (notificationIcon) {
            notificationIcon.addEventListener('click', function (e) {
                e.stopPropagation();
                this.classList.toggle('active');
            });
        }

        // User dropdown toggle
        const userDropdown = document.querySelector('.navbar-user');
        const userDropdownMenu = document.querySelector('.user-dropdown-menu');
        if (userDropdown && userDropdownMenu) {
            userDropdown.addEventListener('click', function (e) {
                e.stopPropagation();
                userDropdownMenu.classList.toggle('show');
            });

            document.addEventListener('click', function () {
                userDropdownMenu.classList.remove('show');
            });
        }
    </script>
</body>
</html>
