@model IEnumerable<ELNETFINALPROJECT.Models.Announcement>
@{
    ViewData["Title"] = "Manage Announcements";
    Layout = "_AdminLayout";
}

<div class="dashboard-header">
    <h1 class="dashboard-title">Manage Announcements</h1>
    <p class="dashboard-subtitle">Create and edit important announcements</p>
</div>

<div class="content-grid" style="grid-template-columns: 1fr;">
    <div class="card-custom">
        <div class="card-title">Create New Announcement</div>
        <form method="post" style="max-width: 600px;">
            <div class="form-group">
                <label for="announcementTitle" class="form-label">Title</label>
                <input type="text" id="announcementTitle" name="title" class="form-control" placeholder="Announcement title..." required />
            </div>

            <div class="form-group">
                <label for="announcementContent" class="form-label">Content</label>
                <textarea id="announcementContent" name="content" class="form-control" rows="6" placeholder="Enter your announcement..." required></textarea>
            </div>

            <button type="submit" class="btn-submit">
                <i class="bi bi-send"></i> Post Announcement
            </button>
        </form>
    </div>
</div>

<div class="card-custom">
    <div class="card-title">All Announcements</div>

    @if (Model == null || !Model.Any())
    {
        <div style="padding:20px;">No announcements yet</div>
    }
    else
    {
        foreach (var ann in Model)
        {
            <div class="announcement-item">
                <div style="display: flex; justify-content: space-between; align-items: start;">
                    <div style="flex: 1;">
                        <h3 class="announcement-title">@ann.Title</h3>
                        <p class="announcement-description">@ann.Content</p>
                        <p class="announcement-date"><i class="bi bi-calendar-event"></i> Posted on @ann.DatePosted.ToString("MMM dd, yyyy")</p>
                    </div>
                    <div class="announcement-actions">
                        <button class="btn-edit" title="Edit"><i class="bi bi-pencil"></i> Edit</button>
                        <button class="btn-delete" onclick="deleteAnnouncement(this)" title="Delete"><i class="bi bi-trash"></i> Delete</button>
                    </div>
                </div>
            </div>
        }
    }
</div>

<script>
    function deleteAnnouncement(button) {
        if (confirm('Are you sure you want to delete this announcement?')) {
            button.closest('.announcement-item').remove();
            alert('Announcement deleted successfully');
        }
    }
</script>
