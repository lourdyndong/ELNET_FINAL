@model IEnumerable<ELNETFINALPROJECT.Models.User>
@{
    ViewData["Title"] = "Users Management";
    Layout = "_AdminLayout";
}

<div class="dashboard-header">
    <h1 class="dashboard-title">Users Management</h1>
    <p class="dashboard-subtitle">Manage student and admin accounts</p>
</div>

<div class="card-custom">
    <div class="card-title">
        All Users
        <div style="display: flex; gap: 10px;">
            <select class="form-control" style="width: 150px; padding: 8px 12px; font-size: 0.9rem;">
                <option>All Roles</option>
                <option>Student</option>
                <option>Admin</option>
            </select>
            <button class="btn-action btn-action-primary" onclick="showAddUserForm()" style="width: auto;">
                <i class="bi bi-plus-circle"></i> Add User
            </button>
        </div>
    </div>

    <div style="overflow-x: auto;">
        <table class="requests-table">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Identifier</th>
                    <th>Role</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model == null || !Model.Any())
                {
                    <tr><td colspan="4">No users found</td></tr>
                }
                else
                {
                    foreach (var u in Model)
                    {
                        <tr>
                            <td><strong>@u.FullName</strong></td>
                            <td>@(string.IsNullOrEmpty(u.StudentId) ? u.Username : u.StudentId)</td>
                            <td><span class="status-badge">@u.Role</span></td>
                            <td>
                                <button class="btn-edit" title="Edit"><i class="bi bi-pencil"></i> Edit</button>
                                <button class="btn-delete" onclick="deleteUser(this)" title="Delete"><i class="bi bi-trash"></i> Delete</button>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

<div id="addUserForm" style="display: none; margin-top: 30px;">
    <div class="card-custom">
        <div class="card-title">Add New User</div>
        <form method="post" style="max-width: 600px;">
            <div class="form-group">
                <label for="fullName" class="form-label">Full Name</label>
                <input type="text" id="fullName" name="fullName" class="form-control" placeholder="Enter full name" required />
            </div>

            <div class="form-group">
                <label for="studentId" class="form-label">Student ID (leave blank for admin)</label>
                <input type="text" id="studentId" name="studentId" class="form-control" placeholder="8-digit student ID" />
            </div>

            <div class="form-group">
                <label for="userRole" class="form-label">Role</label>
                <select id="userRole" name="role" class="form-control" required>
                    <option value="">Select Role</option>
                    <option value="Student">Student</option>
                    <option value="Admin">Admin</option>
                </select>
            </div>

            <div class="form-group">
                <label for="password" class="form-label">Password</label>
                <input type="password" id="password" name="password" class="form-control" placeholder="Enter password" required />
            </div>

            <button type="submit" class="btn-submit"><i class="bi bi-check-circle"></i> Add User</button>
            <button type="button" class="btn-submit" style="background-color: #e9ecef; color: #2d3748;" onclick="hideAddUserForm()">Cancel</button>
        </form>
    </div>
</div>

<script>
    function showAddUserForm() { document.getElementById('addUserForm').style.display = 'block'; document.querySelector('.dashboard-header').scrollIntoView({ behavior: 'smooth' }); }
    function hideAddUserForm() { document.getElementById('addUserForm').style.display = 'none'; }
    function deleteUser(button) { if (confirm('Are you sure you want to delete this user?')) { button.closest('tr').remove(); alert('User deleted successfully'); } }
</script>
