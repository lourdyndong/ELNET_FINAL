@model IEnumerable<ELNETFINALPROJECT.Models.Lab>
@{
    ViewData["Title"] = "Labs Management";
    Layout = "_AdminLayout";
}

<div class="dashboard-header">
    <h1 class="dashboard-title">Labs Management</h1>
    <p class="dashboard-subtitle">Manage computer lab rooms and their status</p>
</div>

<div class="content-grid" style="grid-template-columns: 1fr;">
    <div class="card-custom">
        <div class="card-title">
            All Labs
            <button class="btn-action btn-action-primary" onclick="showAddLabForm()" style="width: auto; margin: 0;">
                <i class="bi bi-plus-circle"></i> Add Lab
            </button>
        </div>

        <div style="overflow-x: auto;">
            <table class="requests-table">
                <thead>
                    <tr>
                        <th>Room Number</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model == null || !Model.Any())
                    {
                        <tr><td colspan="3">No labs available</td></tr>
                    }
                    else
                    {
                        foreach (var lab in Model)
                        {
                            <tr>
                                <td><strong>@lab.Room</strong></td>
                                <td>
                                    <span class="status-badge @(lab.Status == "Available" ? "status-approved" : lab.Status == "Occupied" ? "status-rejected" : "")">@lab.Status</span>
                                </td>
                                <td>
                                    <button class="btn-edit" title="Edit"><i class="bi bi-pencil"></i> Edit</button>
                                    <button class="btn-delete" onclick="deleteLab(this)" title="Delete"><i class="bi bi-trash"></i> Delete</button>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div id="addLabForm" style="display: none; margin-top: 30px;">
    <div class="card-custom">
        <div class="card-title">Add New Lab</div>
        <form method="post" style="max-width: 600px;">
            <div class="form-group">
                <label for="roomNumber" class="form-label">Room Number</label>
                <input type="text" id="roomNumber" name="room" class="form-control" placeholder="e.g., 550" required />
            </div>

            <div class="form-group">
                <label for="status" class="form-label">Status</label>
                <select id="status" name="status" class="form-control" required>
                    <option value="">Select Status</option>
                    <option value="Available">Available</option>
                    <option value="Occupied">Occupied</option>
                    <option value="Maintenance">Under Maintenance</option>
                </select>
            </div>

            <button type="submit" class="btn-submit"><i class="bi bi-check-circle"></i> Add Lab</button>
            <button type="button" class="btn-submit" style="background-color: #e9ecef; color: #2d3748;" onclick="hideAddLabForm()">Cancel</button>
        </form>
    </div>
</div>

<script>
    function showAddLabForm() { document.getElementById('addLabForm').style.display = 'block'; document.querySelector('.dashboard-header').scrollIntoView({ behavior: 'smooth' }); }
    function hideAddLabForm() { document.getElementById('addLabForm').style.display = 'none'; }
    function deleteLab(button) { if (confirm('Are you sure you want to delete this lab?')) { button.closest('tr').remove(); alert('Lab deleted successfully'); } }
</script>
