@model IEnumerable<ELNETFINALPROJECT.Models.SitInRequest>
@{
    ViewData["Title"] = "Manage Requests";
    Layout = "_AdminLayout";
}

<div class="dashboard-header">
    <h1 class="dashboard-title">Manage Requests</h1>
    <p class="dashboard-subtitle">Review and approve student sit-in requests</p>
</div>

<div class="card-custom">
    <div class="card-title">
        All Requests
        <div style="display: flex; gap: 10px;">
            <select class="form-control" style="width: 150px; padding: 8px 12px; font-size: 0.9rem;">
                <option>All Status</option>
                <option>Approved</option>
                <option>Pending</option>
                <option>Rejected</option>
            </select>
        </div>
    </div>

    <div style="overflow-x: auto;">
        <table class="requests-table">
            <thead>
                <tr>
                    <th>Student ID</th>
                    <th>Room</th>
                    <th>Date</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model == null || !Model.Any())
                {
                    <tr>
                        <td colspan="5">No requests found</td>
                    </tr>
                }
                else
                {
                    foreach (var r in Model)
                    {
                        <tr>
                            <td>@r.StudentId</td>
                            <td>@("Room " + r.Room)</td>
                            <td>@r.DateTime.ToString("MMM dd, yyyy")</td>
                            <td>
                                @if (r.Status == "Approved") { <span class="status-badge status-approved">Approved</span> }
                                else if (r.Status == "Pending") { <span class="status-badge status-pending">Pending</span> }
                                else { <span class="status-badge status-rejected">Rejected</span> }
                            </td>
                            <td>
                                @if (r.Status == "Pending")
                                {
                                    <button class="btn-approve" onclick="approveRequest(this)">
                                        <i class="bi bi-check"></i> Approve
                                    </button>
                                    <button class="btn-reject" onclick="rejectRequest(this)">
                                        <i class="bi bi-x"></i> Reject
                                    </button>
                                }
                                else
                                {
                                    <button class="btn-edit"><i class="bi bi-eye"></i> View</button>
                                }
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

<script>
    function approveRequest(button) {
        if (confirm('Are you sure you want to approve this request?')) {
            const row = button.closest('tr');
            const statusCell = row.querySelector('.status-badge');
            statusCell.textContent = 'Approved';
            statusCell.className = 'status-badge status-approved';
            button.closest('td').innerHTML = '<button class="btn-edit"><i class="bi bi-eye"></i> View</button>';
            alert('Request approved successfully');
        }
    }

    function rejectRequest(button) {
        if (confirm('Are you sure you want to reject this request?')) {
            const row = button.closest('tr');
            const statusCell = row.querySelector('.status-badge');
            statusCell.textContent = 'Rejected';
            statusCell.className = 'status-badge status-rejected';
            button.closest('td').innerHTML = '<button class="btn-edit"><i class="bi bi-eye"></i> View</button>';
            alert('Request rejected successfully');
        }
    }
</script>
