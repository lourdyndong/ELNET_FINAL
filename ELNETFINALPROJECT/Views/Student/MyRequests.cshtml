@model IEnumerable<ELNETFINALPROJECT.Models.SitInRequest>
@{
    ViewData["Title"] = "My Requests";
    Layout = "_StudentLayout";
}

<div class="dashboard-header">
    <h1 class="dashboard-title">My Requests</h1>
    <p class="dashboard-subtitle">View and manage your sit-in requests</p>
</div>

<div class="card-custom">
    <div class="card-title">
        All Requests
        <button class="btn-action btn-action-primary" onclick="location.href='/Student/RequestSitIn'" style="width: auto; margin: 0;">
            <i class="bi bi-plus-circle"></i> New Request
        </button>
    </div>

    <div style="overflow-x: auto;">
        <table class="requests-table">
            <thead>
                <tr>
                    <th>Room</th>
                    <th>Date</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in Model)
                {
                    <tr>
                        <td>@("Room " + r.Room)</td>
                        <td>@r.DateTime.ToString("MMM dd, yyyy")</td>
                        <td>
                            @if (r.Status == "Approved") { <span class="status-badge status-approved">Approved</span> }
                            else if (r.Status == "Pending") { <span class="status-badge status-pending">Pending</span> }
                            else { <span class="status-badge status-rejected">Rejected</span> }
                        </td>
                        <td>
                            <button class="btn-edit" title="View Details">
                                <i class="bi bi-eye"></i> View
                            </button>
                            @if (r.Status == "Pending")
                            {
                                <button class="btn-delete" title="Cancel Request" onclick="cancelRequest(this)">
                                    <i class="bi bi-trash"></i> Cancel
                                </button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<script>
    function cancelRequest(button) {
        if (confirm('Are you sure you want to cancel this request?')) {
            // In a real app, call backend to cancel. Here we only remove row.
            button.closest('tr').remove();
            alert('Request cancelled successfully');
        }
    }
</script>
