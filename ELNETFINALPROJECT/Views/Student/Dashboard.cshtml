@model ELNETFINALPROJECT.Models.ViewModels.StudentDashboardViewModel
@{
    ViewData["Title"] = "Student Dashboard";
    Layout = "_StudentLayout";
}

<div class="dashboard-header">
    <h1 class="dashboard-title">Welcome, @Model.FullName</h1>
    <p class="dashboard-subtitle">Here's your lab management overview</p>
</div>

<div class="summary-cards">
    <div class="summary-card">
        <div class="summary-card-icon icon-primary">
            <i class="bi bi-chat-dots"></i>
        </div>
        <div class="summary-card-content">
            <h3 class="summary-card-number">@Model.TotalRequests</h3>
            <p class="summary-card-label">Total Requests</p>
        </div>
    </div>

    <div class="summary-card">
        <div class="summary-card-icon icon-success">
            <i class="bi bi-check-circle"></i>
        </div>
        <div class="summary-card-content">
            <h3 class="summary-card-number">@Model.ApprovedRequests</h3>
            <p class="summary-card-label">Approved Requests</p>
        </div>
    </div>

    <div class="summary-card">
        <div class="summary-card-icon icon-warning">
            <i class="bi bi-clock"></i>
        </div>
        <div class="summary-card-content">
            <h3 class="summary-card-number">@Model.PendingRequests</h3>
            <p class="summary-card-label">Pending Requests</p>
        </div>
    </div>
</div>

<div class="content-grid">
    <!-- Left Column: Recent Notifications -->
    <div class="card-custom">
        <div class="card-title">
            Recent Notifications
            <a href="/Student/Notifications" class="view-all">View All</a>
        </div>
        <ul class="notification-list">
            @foreach (var n in Model.Notifications)
            {
                <li class="notification-item">
                    <div class="notification-icon @(n.IsRead ? "info" : "success")">
                        <i class="bi bi-bell"></i>
                    </div>
                    <div class="notification-content">
                        <h4 class="notification-title">@n.Message</h4>
                        <div class="notification-time">@((n.IsRead) ? "Read" : "New")</div>
                    </div>
                </li>
            }
        </ul>
    </div>

    <!-- Right Column: Quick Actions & Available Labs -->
    <div>
        <div class="card-custom" style="margin-bottom: 20px;">
            <div class="card-title">Quick Actions</div>
            <div class="quick-actions">
                <button class="btn-action btn-action-primary" onclick="location.href='/Student/RequestSitIn'">
                    <i class="bi bi-plus-circle"></i>
                    New Request
                </button>
                <button class="btn-action btn-action-secondary" onclick="location.href='/Student/MyRequests'">
                    <i class="bi bi-clock-history"></i>
                    View All Requests
                </button>
                <button class="btn-action btn-action-secondary" onclick="location.href='/Student/Announcements'">
                    <i class="bi bi-megaphone"></i>
                    View Announcements
                </button>
            </div>
        </div>

        <div class="card-custom">
            <div class="card-title">Available Labs</div>
            <ul class="labs-list">
                @if (Model.Labs == null || !Model.Labs.Any())
                {
                    <li>No labs available</li>
                }
                else
                {
                    foreach (var lab in Model.Labs)
                    {
                        <li class="lab-item">
                            <div class="lab-info">
                                <div class="lab-icon">@lab.Room</div>
                                <h4 class="lab-name">Room @lab.Room</h4>
                            </div>
                            <span class="lab-status @(lab.Status == "Available" ? "available" : lab.Status == "Occupied" ? "occupied" : "")">@lab.Status</span>
                        </li>
                    }
                }
            </ul>
        </div>
    </div>
</div>
