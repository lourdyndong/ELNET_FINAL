@model IEnumerable<ELNETFINALPROJECT.Models.Announcement>
@{
    ViewData["Title"] = "Announcements";
    Layout = "_StudentLayout";
}

<div class="dashboard-header">
    <h1 class="dashboard-title">Announcements</h1>
    <p class="dashboard-subtitle">Important updates and information about the lab</p>
</div>

<div style="max-width: 800px;">
    @if (Model == null || !Model.Any())
    {
        <div class="announcement-item">No announcements yet</div>
    }
    else
    {
        foreach (var ann in Model)
        {
            <div class="announcement-item">
                <h3 class="announcement-title">@ann.Title</h3>
                <p class="announcement-description">@ann.Content</p>
                <p class="announcement-date"><i class="bi bi-calendar-event"></i> Posted on @ann.DatePosted.ToString("MMM dd, yyyy")</p>
            </div>
        }
    }
</div>
